---
import Layout from '../layouts/Layout.astro'

interface Props {
  title: string
  description: string
  eyebrow: string
  canonical: string
  intro: string
  noteTitle?: string
  noteBody?: string
  ogImage?: string
}

const {
  title,
  description,
  eyebrow,
  canonical,
  intro,
  noteTitle,
  noteBody,
  ogImage = '/og/og-docs.png',
} = Astro.props
---

<Layout title={title} description={description} ogImage={ogImage} canonical={canonical} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "url": canonical,
      "author": { "@type": "Person", "name": "Ari Mendelow", "url": "https://github.com/arimendelow" },
      "publisher": { "@type": "Person", "name": "Ari Mendelow" }
    })} />
  </Fragment>

  <article class="relative overflow-hidden px-6 pt-32 pb-20 md:pt-40 md:pb-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(74,227,108,0.06),transparent_32%),linear-gradient(180deg,var(--color-void),var(--color-deep)_38%,var(--color-void))]"></div>

    <div class="relative mx-auto max-w-6xl">
      <div class="max-w-3xl mb-10">
        <span class="text-xs text-mist/40 uppercase tracking-wider">{eyebrow}</span>
        <h1 class="mt-5 font-display text-5xl italic leading-tight text-bone md:text-6xl lg:text-7xl">
          {title}
        </h1>
        <p class="mt-6 text-lg leading-8 text-mist md:text-xl">
          {description}
        </p>
      </div>

      {(noteTitle || noteBody || intro) && (
        <div class="grid gap-5 lg:grid-cols-2 mb-16">
          {intro && (
            <div class="rounded-2xl border border-canopy bg-undergrowth/30 p-7">
              <p class="text-sm leading-7 text-mist">{intro}</p>
            </div>
          )}
          {(noteTitle || noteBody) && (
            <aside class="rounded-2xl border border-canopy bg-undergrowth/30 p-7">
              {noteTitle && <p class="font-display text-xl italic text-bone">{noteTitle}</p>}
              {noteBody && <p class="mt-3 text-sm leading-7 text-mist">{noteBody}</p>}
              <slot name="aside" />
            </aside>
          )}
        </div>
      )}

      <div class="relative space-y-14">
        <slot />
      </div>
    </div>
  </article>
</Layout>
