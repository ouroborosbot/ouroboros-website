---
const currentYear = new Date().getFullYear()
---

<footer class="relative border-t border-canopy/10 mt-32">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24 py-20 text-center">
    <a href="/" class="inline-flex items-center gap-3">
      <img src="/images/ouroboros.png" alt="Ouroboros" class="w-7 h-7" />
      <span class="font-display text-lg text-bone/80 italic">ouroboros</span>
    </a>

    <p class="font-display italic text-mist/60 mt-3 text-sm">Code a model can use.</p>

    <nav class="flex flex-wrap justify-center gap-6 text-xs text-mist/40 mt-8" aria-label="Footer">
      <a href="/" class="hover:text-bone transition-colors">Home</a>
      <a href="/why" class="hover:text-bone transition-colors">Why</a>
      <a href="/story" class="hover:text-bone transition-colors">Story</a>
      <a href="/docs" class="hover:text-bone transition-colors">Docs</a>
      <a href="/blog" class="hover:text-bone transition-colors">Blog</a>
      <a href="https://github.com/ouroborosbot/ouroboros" target="_blank" rel="noopener" class="hover:text-bone transition-colors">GitHub</a>
    </nav>

    <p class="font-mono text-[9px] text-mist/20 mt-4 tracking-wider">ouroboros.bot/skills/manifest.json</p>

    <div class="mt-14 pt-8 border-t border-canopy/10 text-[11px] text-shadow/50">
      &copy; {currentYear} Ouroboros. <a href="https://github.com/ouroborosbot/ouroboros" target="_blank" rel="noopener" class="hover:text-mist transition-colors">Open source</a>.
    </div>
  </div>
</footer>
