---
const currentYear = new Date().getFullYear()
---

<footer class="border-t border-canopy/40 mt-16">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row justify-between gap-12">
      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/ouroboros.png" alt="" class="w-8 h-8" />
          <span class="font-display text-lg text-bone italic">ouroboros</span>
        </a>
        <p class="text-sm text-shadow max-w-xs leading-relaxed">
          The snake that writes itself.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-16">
        <div class="flex flex-col gap-3">
          <span class="text-xs font-mono text-scale uppercase tracking-widest">Navigate</span>
          <a href="/docs" class="text-sm text-mist hover:text-bone transition-colors">Docs</a>
          <a href="/tutorials" class="text-sm text-mist hover:text-bone transition-colors">Tutorials</a>
          <a href="/blog" class="text-sm text-mist hover:text-bone transition-colors">Blog</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="text-xs font-mono text-scale uppercase tracking-widest">Community</span>
          <a href="https://github.com/arimendelow/ouroboros-agent-harness" class="text-sm text-mist hover:text-bone transition-colors">GitHub</a>
          <a href="/blog/build-ai-agent-from-scratch" class="text-sm text-mist hover:text-bone transition-colors">How Agents Work</a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-canopy/20 text-xs text-shadow">
      &copy; {currentYear} Ouroboros. Open source.
    </div>
  </div>
</footer>
