---
const links = [
  { href: '/', label: 'Home' },
  { href: '/why', label: 'Why' },
  { href: '/story', label: 'Story' },
  { href: '/docs', label: 'Docs' },
  { href: '/blog', label: 'Blog' },
]
const currentPath = Astro.url.pathname
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href)
const isHomepage = currentPath === '/'
---

<nav class="fixed top-0 inset-x-0 z-40" id="main-nav" data-homepage={isHomepage ? 'true' : undefined}>
  <div id="nav-bg" class:list={[
    'transition-all duration-500',
    isHomepage ? 'bg-transparent' : 'bg-deep/90 backdrop-blur-lg border-b border-canopy/15'
  ]}>
    <div class="max-w-7xl mx-auto flex items-center justify-between h-16 px-6 md:px-12 lg:px-24">
      <a href="/" class="flex items-center gap-3 group">
        <img src="/images/ouroboros.png" alt="Ouroboros" class="w-8 h-8 transition-transform duration-500 group-hover:rotate-12" />
        <span class="font-display text-xl text-bone italic">ouroboros</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {links.map(link => (
          <a href={link.href} class:list={[
            'font-display italic text-sm tracking-wide transition-colors duration-200',
            isActive(link.href) ? 'text-scale' : 'text-mist/70 hover:text-bone'
          ]}>
            {link.label}
          </a>
        ))}
        <a href="https://github.com/ouroborosbot/ouroboros" target="_blank" rel="noopener" class="text-mist/50 hover:text-bone transition-colors" aria-label="GitHub">
          <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>

      <button class="md:hidden text-mist hover:text-bone transition-colors" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 top-16 bg-deep/95 backdrop-blur-2xl z-30">
    <div class="flex flex-col items-center gap-10 pt-24">
      {links.map(link => (
        <a href={link.href} class:list={[
          'font-display italic text-4xl tracking-wide transition-colors duration-200',
          isActive(link.href) ? 'text-scale' : 'text-mist hover:text-bone'
        ]}>
          {link.label}
        </a>
      ))}
      <a href="https://github.com/ouroborosbot/ouroboros" target="_blank" rel="noopener" class="text-mist hover:text-bone transition-colors mt-4 font-display italic text-xl">
        GitHub &rarr;
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function() {
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    var iconOpen = document.getElementById('menu-icon-open');
    var iconClose = document.getElementById('menu-icon-close');
    if (toggle) {
      toggle.addEventListener('click', function() {
        var isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        iconOpen.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!isOpen));
        document.body.style.overflow = isOpen ? '' : 'hidden';
      });
    }
    if (menu) {
      menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          menu.classList.add('hidden');
          iconOpen.classList.remove('hidden');
          iconClose.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      });
    }
    // Homepage: transparent nav, solidifies on scroll
    var nav = document.getElementById('main-nav');
    var navBg = document.getElementById('nav-bg');
    if (nav && nav.dataset.homepage && navBg) {
      var scrolled = false;
      function updateNav() {
        var shouldBeOpaque = window.scrollY > 80;
        if (shouldBeOpaque !== scrolled) {
          scrolled = shouldBeOpaque;
          if (scrolled) {
            navBg.classList.remove('bg-transparent');
            navBg.classList.add('bg-deep/90', 'backdrop-blur-lg', 'border-b', 'border-canopy/15');
          } else {
            navBg.classList.add('bg-transparent');
            navBg.classList.remove('bg-deep/90', 'backdrop-blur-lg', 'border-b', 'border-canopy/15');
          }
        }
      }
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();
    }
  })();
</script>
