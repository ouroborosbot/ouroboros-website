---
interface Props {
  size?: 'sm' | 'md' | 'lg'
  id?: string
}

const { size = 'md', id = 'ring' } = Astro.props

const sizeClasses = {
  sm: 'w-48 h-48 sm:w-56 sm:h-56',
  md: 'w-56 h-56 sm:w-72 sm:h-72 md:w-80 md:h-80',
  lg: 'w-72 h-72 md:w-96 md:h-96',
}

const snakeGradId = `snakeGrad-${id}`
const ringGradId = `ringGrad-${id}`
---

<div class={`relative ${sizeClasses[size]}`}>
  <div class="absolute inset-[-30%] rounded-full bg-scale/6 blur-[80px] pointer-events-none"></div>
  <svg class="absolute inset-0 w-full h-full" viewBox="0 0 200 200" fill="none">
    <circle cx="100" cy="100" r="90" stroke={`url(#${ringGradId})`} stroke-width="0.5" opacity="0.4" class="ouroboros-spin-slow" transform-origin="100 100" />
    <circle cx="100" cy="100" r="72" stroke={`url(#${snakeGradId})`} stroke-width="3" stroke-dasharray="8 4 20 4 40 4" stroke-linecap="round" class="ouroboros-spin" transform-origin="100 100" />
    <circle cx="100" cy="100" r="55" stroke="var(--color-canopy)" stroke-width="1" stroke-dasharray="3 12" opacity="0.5" class="ouroboros-spin-reverse" transform-origin="100 100" />
    <circle cx="100" cy="28" r="5" fill="var(--color-glow)" opacity="0.9" class="ouroboros-spin" transform-origin="100 100">
      <animate attributeName="opacity" values="0.9;0.5;0.9" dur="2s" repeatCount="indefinite" />
    </circle>
    <circle cx="100" cy="28" r="3" fill="var(--color-scale)" opacity="0.4" class="ouroboros-spin-delayed-1" transform-origin="100 100" />
    <circle cx="100" cy="28" r="2" fill="var(--color-scale)" opacity="0.2" class="ouroboros-spin-delayed-2" transform-origin="100 100" />
    <defs>
      <linearGradient id={snakeGradId} x1="0" y1="0" x2="200" y2="200">
        <stop offset="0%" stop-color="var(--color-scale)" />
        <stop offset="50%" stop-color="var(--color-glow)" />
        <stop offset="100%" stop-color="var(--color-canopy)" />
      </linearGradient>
      <linearGradient id={ringGradId} x1="0" y1="0" x2="200" y2="200">
        <stop offset="0%" stop-color="var(--color-scale)" />
        <stop offset="100%" stop-color="transparent" />
      </linearGradient>
    </defs>
  </svg>
  <div class="absolute inset-12 sm:inset-16 rounded-full bg-gradient-to-br from-scale/5 to-glow/3 blur-2xl"></div>
  <div class="absolute inset-0 flex flex-col items-center justify-center text-center gap-0.5">
    <span class="font-mono text-[7px] sm:text-[8px] text-scale/50 uppercase tracking-[0.3em]">context window</span>
    <span class="font-display text-lg sm:text-2xl italic text-bone mt-1 leading-tight">Consume.</span>
    <span class="font-display text-lg sm:text-2xl italic text-mist leading-tight">Remember.</span>
    <span class="font-display text-lg sm:text-2xl italic text-scale/80 leading-tight">Survive.</span>
  </div>
</div>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: no-preference) {
    .ouroboros-spin { animation: spin 25s linear infinite; }
    .ouroboros-spin-slow { animation: spin 80s linear infinite; }
    .ouroboros-spin-reverse { animation: spin 40s linear infinite reverse; }
    .ouroboros-spin-delayed-1 { animation: spin 25s linear infinite; animation-delay: -0.8s; }
    .ouroboros-spin-delayed-2 { animation: spin 25s linear infinite; animation-delay: -1.6s; }
  }
</style>
