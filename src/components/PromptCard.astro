---
interface Props {
  label?: string
  prompt: string
  footnote?: string
}

const {
  label = 'Ask your agent',
  prompt,
  footnote,
} = Astro.props
---

<div class="surface-card">
  <div class="surface-rule flex items-center gap-3 px-5 py-4">
    <span class="h-1.5 w-1.5 rounded-full bg-scale/70"></span>
    <span class="rule-label">{label}</span>
  </div>
  <pre class="whitespace-pre-wrap px-5 py-5 font-mono text-sm leading-7 text-bone/88">{prompt}</pre>
  {footnote && (
    <div class="surface-rule px-5 py-3 text-xs leading-6 text-mist/60">
      {footnote}
    </div>
  )}
</div>
