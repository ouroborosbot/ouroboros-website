---
/**
 * Mock conversation between a human and the serpent guide.
 * Shows the interactive setup experience — not a command dump.
 */
---

<div class="serpent-preview max-w-2xl mx-auto rounded-xl border border-canopy/50 bg-undergrowth/20 overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5),0_0_80px_rgba(45,148,71,0.08)]">
  <!-- Terminal chrome -->
  <div class="flex items-center gap-2 px-5 py-3 border-b border-canopy/30 bg-undergrowth/30">
    <span class="w-2.5 h-2.5 rounded-full bg-fang/50"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-scale/30"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-canopy/40"></span>
    <span class="font-mono text-[10px] text-mist/50 ml-3">terminal</span>
  </div>

  <!-- Conversation -->
  <div class="p-5 md:p-6 space-y-4 font-mono text-sm leading-relaxed">
    <!-- Command -->
    <div>
      <span class="text-mist/50">$</span> <span class="text-bone">npx ouro.bot</span>
    </div>
    <div class="text-glow/60">&#x1F95A; &#x2192; &#x1F40D;</div>

    <!-- Serpent asks name -->
    <div class="border-l-2 border-scale/30 pl-4">
      <span class="text-scale/80 text-xs uppercase tracking-wider">serpent</span>
      <p class="text-bone/90 mt-1">What should we call this agent?</p>
    </div>
    <div class="pl-4">
      <span class="text-mist/40 text-xs uppercase tracking-wider">you</span>
      <p class="text-bone mt-1">Atlas</p>
    </div>

    <!-- Serpent asks provider -->
    <div class="border-l-2 border-scale/30 pl-4">
      <span class="text-scale/80 text-xs uppercase tracking-wider">serpent</span>
      <p class="text-bone/90 mt-1">Which provider?</p>
      <p class="text-mist/50 text-xs mt-0.5">anthropic &middot; openai &middot; local</p>
    </div>
    <div class="pl-4">
      <span class="text-mist/40 text-xs uppercase tracking-wider">you</span>
      <p class="text-bone mt-1">anthropic</p>
    </div>

    <!-- Serpent asks personality -->
    <div class="border-l-2 border-scale/30 pl-4">
      <span class="text-scale/80 text-xs uppercase tracking-wider">serpent</span>
      <p class="text-bone/90 mt-1">Describe the personality in a sentence or two.</p>
    </div>
    <div class="pl-4">
      <span class="text-mist/40 text-xs uppercase tracking-wider">you</span>
      <p class="text-bone mt-1">Thoughtful and direct. Remembers context, doesn't waste words.</p>
    </div>

    <!-- Hatching -->
    <div class="border-l-2 border-scale/30 pl-4">
      <span class="text-scale/80 text-xs uppercase tracking-wider">serpent</span>
      <div class="mt-1 space-y-1">
        <p class="text-mist/70">Hatching Atlas&hellip;</p>
        <p class="text-glow/70"><span class="text-scale">&#10003;</span> Bundle created at <span class="text-bone/70">~/AgentBundles/Atlas.ouro</span></p>
        <p class="text-glow/70"><span class="text-scale">&#10003;</span> Psyche initialized</p>
        <p class="text-glow/70"><span class="text-scale">&#10003;</span> Provider configured</p>
      </div>
    </div>

    <!-- Ready -->
    <div class="border-l-2 border-glow/40 pl-4 py-1">
      <span class="text-scale/80 text-xs uppercase tracking-wider">serpent</span>
      <p class="text-glow/90 mt-1">Atlas is ready. Say hello.</p>
    </div>

    <!-- First interaction -->
    <div class="pt-2 border-t border-canopy/20">
      <div>
        <span class="text-mist/50">$</span> <span class="text-bone">ouro</span>
      </div>
      <div class="mt-2 border-l-2 border-bone/20 pl-4">
        <span class="text-bone/60 text-xs uppercase tracking-wider">Atlas</span>
        <p class="text-bone mt-1">Hey. What are we working on?<span class="serpent-cursor"></span></p>
      </div>
    </div>
  </div>
</div>

<style>
  .serpent-cursor {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--color-bone);
    opacity: 0.7;
    margin-left: 2px;
    vertical-align: middle;
    animation: serpent-blink 1.2s step-end infinite;
  }
  @keyframes serpent-blink {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 0; }
  }
</style>
