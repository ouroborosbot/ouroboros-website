---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
  ogImage?: string
}

const {
  title,
  description = 'A multi-agent harness for building AI agents that know who they are.',
  ogImage = '/og/og-home.png',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/images/ouroboros.svg" />
    <title>{title}</title>

    <!-- Fonts self-hosted in /fonts/ — no external dependency -->

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`https://ouroboros.bot${ogImage}`} />
    <meta property="og:url" content={`https://ouroboros.bot${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Ouroboros" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://ouroboros.bot${ogImage}`} />
    <meta name="twitter:site" content="@arimendelow" />
    <meta name="twitter:creator" content="@arimendelow" />
    <link rel="canonical" href={`https://ouroboros.bot${Astro.url.pathname}`} />
    <slot name="head" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ouroboros",
      "url": "https://ouroboros.bot",
      "description": "A zero-dependency TypeScript framework for AI agents that self-modify, remember, and grow.",
      "publisher": {
        "@type": "Person",
        "name": "Ari Mendelow",
        "url": "https://linkedin.com/in/arimendelow"
      }
    })} />

  </head>
  <body class="bg-void text-bone font-body antialiased overflow-x-hidden">
    <!-- Grain overlay -->
    <svg class="fixed inset-0 w-full h-full pointer-events-none z-50 opacity-[0.03]" aria-hidden="true">
      <filter id="grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grain)" />
    </svg>

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Reveal sections on scroll — progressive enhancement
      // Sections default to visible; we add reveal-ready to enable animations only when JS + observer are available
      (function() {
        var reveals = document.querySelectorAll('.reveal');
        if (!reveals.length || !('IntersectionObserver' in window)) return;

        // Mark sections already in viewport as visible BEFORE enabling animations
        // This prevents the flash-of-invisible-content on page navigation
        reveals.forEach(function(el) {
          var rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add('visible');
          }
        });

        // Now enable animations (only hides sections not yet marked visible)
        document.documentElement.classList.add('reveal-ready');

        var observer = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: '0px 0px 80px 0px' }
        );
        reveals.forEach(function(el) {
          if (!el.classList.contains('visible')) observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
