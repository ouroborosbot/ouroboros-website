---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Ouroboros">

  <section class="relative flex min-h-[80vh] items-center justify-center px-6 py-24">
    <div class="surface-card relative z-10 max-w-xl p-10 text-center md:p-12">
      <span class="eyebrow-tag justify-center">404</span>

      <h1 class="mt-6 font-display text-6xl italic leading-tight text-bone md:text-8xl">
        Lost in<br />the coils.
      </h1>

      <p class="text-base text-mist/70 mt-6 leading-relaxed">
        This page has been consumed by the context window. Nothing remains.
      </p>

      <a href="/" class="action-secondary mt-10">
        Return to the beginning
      </a>
    </div>
  </section>

</Layout>
