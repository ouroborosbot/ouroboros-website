---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Ouroboros">

  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-6">
    <div class="relative z-10 text-center max-w-lg">
      <span class="text-xs text-mist/40 uppercase tracking-wider block mb-6">404</span>

      <h1 class="font-display text-6xl md:text-8xl italic text-bone leading-tight">
        Lost in<br />the coils.
      </h1>

      <p class="text-base text-mist/70 mt-6 leading-relaxed">
        This page has been consumed by the context window. Nothing remains.
      </p>

      <a href="/" class="inline-block mt-10 px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
        Return to the beginning
      </a>
    </div>
  </section>

</Layout>
