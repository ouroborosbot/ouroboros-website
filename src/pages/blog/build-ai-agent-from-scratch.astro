    <span class="text-mist">const</span> <span class="text-bone">response</span> <span class="text-shadow">=</span> <span class="text-mist">await</span> <span class="text-bone">streamChatWithTools</span><span class="text-shadow">(</span><span class="text-bone">messages</span><span class="text-shadow">)</span>
