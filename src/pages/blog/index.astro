---
import Layout from '../../layouts/Layout.astro'

const posts = [
  {
    title: 'How to Build an AI Agent from Scratch',
    description: 'Build a working AI agent in ~150 lines of TypeScript. Five milestones: first API call, streaming, multi-turn conversation, tools, and the agentic loop.',
    href: '/blog/build-ai-agent-from-scratch',
    date: '2026-03-01',
    tag: 'Tutorial',
    readTime: '25 min read',
    author: 'Ari Mendelow',
  },
]
---

<Layout title="Blog — Ouroboros" description="Essays on agent architecture, framework design, and building software that knows itself.">

  <Fragment slot="head">
    <link rel="canonical" href="https://ouroboros.bot/blog" />
    <meta property="og:url" content="https://ouroboros.bot/blog" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Ouroboros Blog",
      "description": "Essays on agent architecture, framework design, and building software that knows itself.",
      "url": "https://ouroboros.bot/blog",
      "publisher": { "@type": "Person", "name": "Ari Mendelow", "url": "https://x.com/arimendelow" }
    })} />
  </Fragment>

  <section class="relative pt-40 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Blog</span>
      <h1 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
        Dispatches from<br />the serpent.
      </h1>
      <p class="text-base text-mist/70 mt-6 leading-relaxed max-w-lg">
        Essays on agent architecture, framework design, and the philosophy of building software that knows itself.
      </p>
    </div>
  </section>

  <section class="px-6 pb-32">
    <div class="max-w-3xl mx-auto space-y-6">
      {posts.map(post => (
        <a href={post.href} class="group block rounded-xl border border-canopy/40 bg-gradient-to-br from-deep/90 to-undergrowth/30 p-8 transition-all duration-500 hover:border-scale/30 hover:translate-y-[-2px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.08)]">
          <div class="flex items-center gap-3 mb-4">
            <span class="font-mono text-[10px] text-scale/60 uppercase tracking-[0.2em] border border-scale/20 rounded-full px-3 py-1">{post.tag}</span>
            <span class="font-mono text-[10px] text-shadow/50">{post.date}</span>
            <span class="font-mono text-[10px] text-shadow/50">{post.readTime}</span>
          </div>
          <h2 class="font-display text-2xl md:text-3xl italic text-bone leading-snug group-hover:text-glow transition-colors duration-300">
            {post.title}
          </h2>
          <p class="text-sm text-mist/60 mt-3 leading-relaxed">{post.description}</p>
          <p class="text-xs text-shadow/50 mt-4">By {post.author}</p>
        </a>
      ))}
    </div>
  </section>

</Layout>
