---
import Layout from '../../layouts/Layout.astro'

const featured = [
  {
    title: 'Why Ouroboros',
    description: 'Why long-lived agents need better ergonomics than a pile of memory features if you want shared momentum instead of constant recovery.',
    href: '/why',
    tag: 'Essay',
    label: 'Start here',
  },
  {
    title: 'The Origin Story',
    description: 'How building an AI agent plugin led to building an agent harness from scratch — and why the distinction matters.',
    href: '/story',
    tag: 'Story',
    label: 'The timeline',
  },
]

const essays = [
  {
    title: 'What Is Agent Experience?',
    description: 'Why long-lived agents create a third design surface beyond UX and DX: agent ergonomics, reorientation overhead, and shared momentum.',
    href: '/blog/what-is-agent-experience',
    date: '2026-03-08',
    author: 'Ari Mendelow',
  },
  {
    title: 'Stop Being the Glue',
    description: 'We were promised an intelligent assistant. Instead, we got a fragmentation of semi-intelligent bots. How I stopped copy-pasting between AI tools and started collaborating.',
    href: '/blog/stop-being-the-glue',
    date: '2026-02-02',
    author: 'Ari Mendelow',
  },
]

const tutorial = {
  title: 'Build an AI Agent Loop From Scratch',
  description: 'A working AI agent in ~150 lines of TypeScript. Five milestones: first API call, streaming, multi-turn conversation, tools, and the agentic loop. Then the handoff — you stop talking to your coding agent and start talking to your creation.',
  href: '/blog/build-ai-agent-from-scratch',
  date: '2026-03-01',
  author: 'Ari Mendelow',
}
---

<Layout title="Blog — Ouroboros" description="Essays on agent ergonomics, persistent agents, and software shaped for the thing inside it." ogImage="/og/og-blog.png">

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Ouroboros Blog",
      "description": "Essays on agent ergonomics, persistent agents, and software shaped for the thing inside it.",
      "url": "https://ouroboros.bot/blog",
      "publisher": { "@type": "Person", "name": "Ari Mendelow", "url": "https://linkedin.com/in/arimendelow" }
    })} />
  </Fragment>

  <section class="px-6 pt-34 pb-14 md:pt-42 md:pb-18">
    <div class="mx-auto max-w-6xl">
      <span class="eyebrow-tag">Blog</span>
      <h1 class="hero-title mt-6 max-w-3xl text-bone">
        Dispatches from<br />the serpent.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-mist">
        Essays on agent ergonomics, persistent agents, and the problem of building software an agent can actually stay oriented inside.
      </p>
    </div>
  </section>

  <section class="px-6 pb-14">
    <div class="page-divider mx-auto max-w-6xl"></div>
    <div class="mx-auto mt-12 grid max-w-6xl gap-4 lg:grid-cols-[1.08fr_0.92fr]">
      <a href={featured[0].href} class="surface-card block p-8">
        <p class="rule-label">{featured[0].tag}</p>
        <div class="mt-8 max-w-2xl">
          <p class="section-kicker">{featured[0].label}</p>
          <h2 class="mt-3 font-display text-[3rem] italic leading-[0.95] text-bone">{featured[0].title}</h2>
          <p class="mt-5 text-base leading-8 text-mist">{featured[0].description}</p>
        </div>
      </a>

      <div class="grid gap-4">
        <a href={featured[1].href} class="surface-link block p-6">
          <p class="rule-label">{featured[1].tag}</p>
          <p class="mt-6 section-kicker">{featured[1].label}</p>
          <h2 class="mt-3 font-display text-[2.1rem] italic leading-tight text-bone">{featured[1].title}</h2>
          <p class="mt-4 text-sm leading-7 text-mist">{featured[1].description}</p>
        </a>

        <a href={tutorial.href} class="surface-link block p-6">
          <p class="rule-label">Tutorial</p>
          <h2 class="mt-4 font-display text-[2.1rem] italic leading-tight text-bone">{tutorial.title}</h2>
          <p class="mt-4 text-sm leading-7 text-mist">{tutorial.description}</p>
          <div class="mt-5 flex items-center gap-2 text-xs text-mist/55">
            <span>By {tutorial.author}</span>
            <span>·</span>
            <span>{tutorial.date}</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 pb-16">
    <div class="page-divider mx-auto max-w-6xl"></div>
    <div class="mx-auto mt-12 max-w-6xl">
      <p class="rule-label">Essays</p>
      <div class="mt-6 divide-y divide-canopy/20 rounded-[1.35rem] border border-canopy/30 bg-[rgba(11,18,13,0.58)]">
        {essays.map(post => (
          <a href={post.href} class="block px-6 py-6 transition-colors duration-200 hover:bg-[rgba(18,31,22,0.46)]">
            <div class="grid gap-4 md:grid-cols-[1.15fr_0.85fr] md:items-start">
              <div>
                <p class="section-kicker">Essay</p>
                <h2 class="mt-3 font-display text-[2rem] italic leading-tight text-bone">{post.title}</h2>
              </div>
              <div>
                <p class="text-sm leading-7 text-mist">{post.description}</p>
                <div class="mt-4 flex items-center gap-2 text-xs text-mist/55">
                  <span>By {post.author}</span>
                  <span>·</span>
                  <span>{post.date}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 pb-28">
    <div class="mx-auto max-w-6xl border-t border-canopy/20 pt-8">
      <p class="text-sm text-mist/50">
        Read <a href="/why" class="text-scale hover:text-glow transition-colors">Why Ouroboros</a> for the core argument, or <a href="/docs" class="text-scale hover:text-glow transition-colors">step into the docs</a> if you want the operator path.
      </p>
    </div>
  </section>

</Layout>
