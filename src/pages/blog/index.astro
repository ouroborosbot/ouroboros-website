---
import Layout from '../../layouts/Layout.astro'

const featured = [
  {
    title: 'Why Ouroboros',
    description: 'Why long-lived agents need better ergonomics than a pile of memory features if you want shared momentum instead of constant recovery.',
    href: '/why',
    tag: 'Essay',
    label: 'Start here',
  },
  {
    title: 'The Origin Story',
    description: 'How building an AI agent plugin led to building an agent harness from scratch — and why the distinction matters.',
    href: '/story',
    tag: 'Story',
    label: 'The timeline',
  },
]

const essays = [
  {
    title: 'What Is Agent Experience?',
    description: 'Why long-lived agents create a third design surface beyond UX and DX: agent ergonomics, reorientation overhead, and shared momentum.',
    href: '/blog/what-is-agent-experience',
    date: '2026-03-08',
    author: 'Ari Mendelow',
  },
  {
    title: 'Stop Being the Glue',
    description: 'We were promised an intelligent assistant. Instead, we got a fragmentation of semi-intelligent bots. How I stopped copy-pasting between AI tools and started collaborating.',
    href: '/blog/stop-being-the-glue',
    date: '2026-02-02',
    author: 'Ari Mendelow',
  },
]

const tutorial = {
  title: 'Build an AI Agent Loop From Scratch',
  description: 'A working AI agent in ~150 lines of TypeScript. Five milestones: first API call, streaming, multi-turn conversation, tools, and the agentic loop. Then the handoff — you stop talking to your coding agent and start talking to your creation.',
  href: '/blog/build-ai-agent-from-scratch',
  date: '2026-03-01',
  author: 'Ari Mendelow',
}
---

<Layout title="Blog — Ouroboros" description="Essays on agent ergonomics, persistent agents, and software shaped for the thing inside it." ogImage="/og/og-blog.png">

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Ouroboros Blog",
      "description": "Essays on agent ergonomics, persistent agents, and software shaped for the thing inside it.",
      "url": "https://ouroboros.bot/blog",
      "publisher": { "@type": "Person", "name": "Ari Mendelow", "url": "https://linkedin.com/in/arimendelow" }
    })} />
  </Fragment>

  <section class="relative overflow-hidden pt-40 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Blog</span>
      <h1 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
        Dispatches from<br />the serpent.
      </h1>
      <p class="text-base text-mist/70 mt-6 leading-relaxed max-w-lg">
        Essays on agent ergonomics, persistent agents, and the problem of building software an agent can actually stay oriented inside.
      </p>
    </div>
  </section>

  <!-- Featured reading -->
  <section class="px-6 pb-12">
    <div class="max-w-3xl mx-auto">
      <span class="font-mono text-[10px] text-mist/50 uppercase tracking-[0.2em] block mb-6">Recommended reading</span>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {featured.map(post => (
          <a href={post.href} class="group block rounded-xl border border-canopy/40 bg-gradient-to-br from-deep/90 to-undergrowth/30 p-6 transition-all duration-500 hover:border-scale/30 hover:translate-y-[-2px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.08)]">
            <div class="flex items-center gap-3 mb-3">
              <span class="font-mono text-[10px] text-scale/60 uppercase tracking-[0.2em] border border-scale/20 rounded-full px-3 py-1">{post.tag}</span>
              <span class="font-mono text-[10px] text-scale/40">{post.label}</span>
            </div>
            <h2 class="font-display text-xl italic text-bone leading-snug group-hover:text-glow transition-colors duration-300">
              {post.title}
            </h2>
            <p class="text-xs text-mist/60 mt-2 leading-relaxed">{post.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tutorial (prominent) -->
  <section class="px-6 pb-12">
    <div class="max-w-3xl mx-auto">
      <span class="font-mono text-[10px] text-mist/50 uppercase tracking-[0.2em] block mb-6">Tutorial</span>
      <a href={tutorial.href} class="group block rounded-xl border border-scale/30 bg-gradient-to-br from-undergrowth/60 to-deep p-8 transition-all duration-500 hover:border-glow/40 hover:translate-y-[-2px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.12)]">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[10px] text-void bg-scale/80 uppercase tracking-[0.2em] rounded-full px-3 py-1 font-medium">Tutorial</span>
        </div>
        <h2 class="font-display text-2xl md:text-3xl italic text-bone leading-snug group-hover:text-glow transition-colors duration-300">
          {tutorial.title}
        </h2>
        <p class="text-sm text-mist/70 mt-3 leading-relaxed">{tutorial.description}</p>
        <div class="flex items-center gap-2 mt-5">
          <span class="text-xs text-mist/40">By {tutorial.author}</span>
          <span class="text-xs text-mist/30">·</span>
          <span class="text-xs text-mist/40">{tutorial.date}</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Essays -->
  <section class="px-6 pb-12">
    <div class="max-w-3xl mx-auto">
      <span class="font-mono text-[10px] text-mist/50 uppercase tracking-[0.2em] block mb-6">Essays</span>
      {essays.map(post => (
        <a href={post.href} class="group block rounded-xl border border-canopy/30 bg-gradient-to-br from-deep/80 to-undergrowth/20 p-6 transition-all duration-500 hover:border-scale/30 hover:translate-y-[-2px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.08)]">
          <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10px] text-scale/60 uppercase tracking-[0.2em] border border-scale/20 rounded-full px-3 py-1">Essay</span>
          </div>
          <h2 class="font-display text-xl italic text-bone leading-snug group-hover:text-glow transition-colors duration-300">
            {post.title}
          </h2>
          <p class="text-xs text-mist/60 mt-2 leading-relaxed">{post.description}</p>
          <div class="flex items-center gap-2 mt-4">
            <span class="text-xs text-mist/40">By {post.author}</span>
            <span class="text-xs text-mist/30">·</span>
            <span class="text-xs text-mist/40">{post.date}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="px-6 pb-32">
    <div class="max-w-3xl mx-auto pt-8 border-t border-canopy/20">
      <p class="text-sm text-mist/50">
        Read <a href="/why" class="text-scale hover:text-glow transition-colors">Why Ouroboros</a> for the core argument, or <a href="/docs" class="text-scale hover:text-glow transition-colors">step into the docs</a> if you want the operator path.
      </p>
    </div>
  </section>

</Layout>
