---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Docs — Ouroboros" description="Documentation for the ouroboros agent framework. Coming soon — browse the source in the meantime." ogImage="/og/og-docs.png">

  <section class="relative overflow-hidden min-h-[80vh] flex flex-col items-center justify-center px-6 pt-28">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-scale/4 blur-[180px] pointer-events-none"></div>

    <div class="relative z-10 text-center max-w-xl">
      <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Documentation</span>

      <h1 class="font-display text-5xl md:text-7xl italic text-bone leading-tight">
        Shedding soon.
      </h1>

      <p class="text-base text-mist/70 mt-6 leading-relaxed">
        Full documentation is being written. In the meantime, the source is the best guide — it's well-commented, fully tested, and the naming tells you what everything does.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-10 justify-center">
        <a href="https://github.com/arimendelow/ouroboros-agent-harness" target="_blank" rel="noopener" class="group px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Browse the Source
        </a>
        <a href="/blog/build-ai-agent-from-scratch" class="px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
          Read the Tutorial
        </a>
      </div>

      <p class="text-xs text-shadow/50 mt-12 italic">
        Want to be notified when docs ship? Star the repo on GitHub.
      </p>
    </div>
  </section>

</Layout>
