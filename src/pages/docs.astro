---
import Layout from '../layouts/Layout.astro'

const title = "Docs — Ouroboros"
const description = "Documentation for humans. Skills for agents. Learn the architecture, then hand your agent the skill URL."

const sections = [
  {
    id: 'quickstart',
    label: 'Quick Start',
    title: 'Hatch your first agent.',
    description: 'An agent bundle is a directory with a manifest and a psyche. Create one in five minutes.',
    skill: {
      id: 'bootstrap-agent',
      name: 'Bootstrap a New Agent',
      url: 'https://ouroboros.bot/skills/bootstrap-agent.md',
    },
    prompt: 'Create a new Ouroboros agent bundle called "my-agent" with an anthropic provider, 80k context window, and psyche files for a helpful coding assistant.',
    details: [
      { label: 'agent.json', desc: 'The manifest: name, provider, context limits, loading phrases.' },
      { label: 'psyche/', desc: 'Five markdown files that define who your agent is.' },
      { label: 'ouro chat', desc: 'Start talking. The daemon handles the rest.' },
    ],
  },
  {
    id: 'architecture',
    label: 'Architecture',
    title: 'Every module is an organ.',
    description: 'The codebase uses a creature-body metaphor. Each top-level directory has a single responsibility, named so the model understands its purpose instinctively — because agents wrote the structure.',
    skill: {
      id: 'understand-architecture',
      name: 'Understand the Body Architecture',
      url: 'https://ouroboros.bot/skills/understand-architecture.md',
    },
    organs: [
      { name: 'heart/', desc: 'The agent loop. Streaming, provider adapters, self-correction.' },
      { name: 'mind/', desc: 'System prompt assembly. Sliding context window. Memory extraction.' },
      { name: 'senses/', desc: 'Channel adapters. CLI. Teams. How the agent perceives.' },
      { name: 'repertoire/', desc: 'Tools, skills, tasks, coding orchestration.' },
      { name: 'daemon/', desc: 'Process manager, scheduler, health monitor.' },
      { name: 'nerves/', desc: 'Runtime observability. Event-based logging.' },
    ],
  },
  {
    id: 'psyche',
    label: 'Psyche',
    title: 'Identity is a directory, not a config file.',
    description: 'Five markdown files define your agent\'s mind. They load into the system prompt every turn, so identity survives every context reset.',
    skill: {
      id: 'understand-psyche',
      name: 'Understand the Psyche System',
      url: 'https://ouroboros.bot/skills/understand-psyche.md',
    },
    prompt: 'Read my psyche files and tell me about yourself. What are your core invariants from SOUL.md? How does your IDENTITY.md shape your voice?',
    files: [
      { name: 'SOUL.md', role: 'What you are', color: 'scale' },
      { name: 'IDENTITY.md', role: 'How you show up', color: 'glow' },
      { name: 'LORE.md', role: 'Where you come from', color: 'scale' },
      { name: 'FRIENDS.md', role: 'Who you know', color: 'glow' },
      { name: 'TACIT.md', role: 'What you\'ve learned', color: 'scale' },
    ],
  },
  {
    id: 'context',
    label: 'Context Window',
    title: 'The snake eats its tail.',
    description: 'When conversation grows too long, the oldest messages are consumed. But facts are extracted to memory first. Nothing is truly lost — it\'s metabolized.',
    skill: {
      id: 'use-sliding-context',
      name: 'Use the Sliding Context Window',
      url: 'https://ouroboros.bot/skills/use-sliding-context.md',
    },
  },
  {
    id: 'tools',
    label: 'Tools & Skills',
    title: 'Reach for the right instrument.',
    description: 'Tools are functions the agent calls during its turn. Skills are markdown files loaded on demand — instruction manuals the agent reads when it needs to learn something new.',
    skill: {
      id: 'build-tools',
      name: 'Build Custom Tools',
      url: 'https://ouroboros.bot/skills/build-tools.md',
    },
    prompt: 'List your available skills, then load the one most relevant to my current task.',
    baseTools: ['read_file', 'write_file', 'shell', 'git_commit', 'gh_cli', 'list_skills', 'load_skill', 'claude', 'web_search', 'save_friend_note'],
  },
  {
    id: 'dream-cycle',
    label: 'Dream Cycle',
    title: 'Sleep. Reflect. Grow.',
    description: 'Overnight, a maintenance process reviews activity, synthesizes memories into psyche files, grooms tasks, and identifies areas for self-improvement. The agent wakes up sharper.',
    skill: {
      id: 'use-dream-cycle',
      name: 'Use the Dream Cycle',
      url: 'https://ouroboros.bot/skills/use-dream-cycle.md',
    },
  },
]
---

<Layout title={title} description={description} ogImage="/og/og-docs.png">

  <Fragment slot="head">
    <link rel="canonical" href="https://ouroboros.bot/docs" />
    <meta property="og:url" content="https://ouroboros.bot/docs" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "url": "https://ouroboros.bot/docs",
      "author": { "@type": "Person", "name": "Ari Mendelow", "url": "https://github.com/arimendelow" },
      "publisher": { "@type": "Person", "name": "Ari Mendelow" }
    })} />
  </Fragment>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative overflow-hidden px-6 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-void via-deep to-void"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-scale/6 blur-[200px] pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto">
      <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Documentation</span>

      <h1 class="font-display text-5xl md:text-7xl italic text-bone leading-tight">
        Docs for humans.<br />
        <span class="text-scale">Skills for agents.</span>
      </h1>

      <p class="text-lg text-mist/80 mt-8 leading-relaxed max-w-2xl">
        Each section explains a concept for <em class="text-bone not-italic">you</em> to understand. Then it links to a skill file
        your <em class="text-bone not-italic">agent</em> can consume directly. You read the what. Your agent reads the how.
      </p>

      <!-- The paradigm explained -->
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl">
        <div class="flex items-start gap-3 px-4 py-3 rounded-lg border border-canopy/40 bg-undergrowth/20">
          <span class="text-bone text-sm mt-0.5">You</span>
          <p class="text-xs text-mist/70 leading-relaxed">Read the docs. Understand the architecture. Decide what to build.</p>
        </div>
        <div class="flex items-start gap-3 px-4 py-3 rounded-lg border border-scale/25 bg-scale/5">
          <span class="text-scale text-sm mt-0.5">Agent</span>
          <p class="text-xs text-mist/70 leading-relaxed">Consumes the skill URL. Gets step-by-step instructions. Does the work.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════ NAV RAIL ═══════════════ -->
  <div class="sticky top-16 z-30 border-b border-canopy/30 bg-void/90 backdrop-blur-xl">
    <div class="max-w-4xl mx-auto px-6">
      <nav class="flex gap-1 overflow-x-auto py-2 scrollbar-hide -mx-2 px-2" aria-label="Documentation sections">
        {sections.map(s => (
          <a
            href={`#${s.id}`}
            class="shrink-0 px-3 py-1.5 text-xs font-mono text-mist/60 hover:text-bone rounded-md hover:bg-undergrowth/40 transition-colors duration-200"
          >
            {s.label}
          </a>
        ))}
      </nav>
    </div>
  </div>


  <!-- ═══════════════ SECTIONS ═══════════════ -->
  {sections.map((section, sectionIndex) => (
    <section id={section.id} class="relative overflow-hidden px-6 py-20 md:py-28 reveal">
      {/* Alternating subtle backgrounds */}
      {sectionIndex % 2 === 1 && (
        <div class="absolute inset-0 bg-deep/50 pointer-events-none"></div>
      )}
      {/* Section border */}
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-canopy/20 to-transparent"></div>

      <div class="max-w-4xl mx-auto relative">
        {/* Section header */}
        <div class="flex items-start justify-between gap-8 mb-10">
          <div class="max-w-xl">
            <span class="font-mono text-[10px] text-scale/60 uppercase tracking-[0.3em] block mb-4">{section.label}</span>
            <h2 class="font-display text-4xl md:text-5xl italic text-bone leading-tight">
              {section.title}
            </h2>
            <p class="text-base text-mist mt-4 leading-relaxed">
              {section.description}
            </p>
          </div>
        </div>

        {/* Section-specific content */}

        {/* Quick Start: steps + prompt */}
        {section.details && (
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            {section.details.map((d, i) => (
              <div class="rounded-lg border border-canopy/40 bg-undergrowth/20 p-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-mono text-xs text-scale/60">{String(i + 1).padStart(2, '0')}</span>
                  <span class="font-mono text-sm text-bone">{d.label}</span>
                </div>
                <p class="text-xs text-mist/70 leading-relaxed">{d.desc}</p>
              </div>
            ))}
          </div>
        )}

        {/* Architecture: organ grid */}
        {section.organs && (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
            {section.organs.map(organ => (
              <div class="rounded-lg border border-canopy/40 bg-undergrowth/20 p-4 hover:border-scale/30 transition-colors duration-200">
                <span class="font-mono text-sm text-scale">{organ.name}</span>
                <p class="text-xs text-mist/70 mt-1 leading-relaxed">{organ.desc}</p>
              </div>
            ))}
          </div>
        )}

        {/* Psyche: file cards */}
        {section.files && (
          <div class="flex flex-wrap gap-2 mb-8">
            {section.files.map(f => (
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg border border-canopy/40 bg-undergrowth/20">
                <div class={`w-1.5 h-1.5 rounded-full ${f.color === 'glow' ? 'bg-glow' : 'bg-scale'}`}></div>
                <span class="font-mono text-xs text-bone">{f.name}</span>
                <span class="text-[10px] text-mist/50">{f.role}</span>
              </div>
            ))}
          </div>
        )}

        {/* Tools: tool list */}
        {section.baseTools && (
          <div class="mb-8">
            <div class="flex flex-wrap gap-1.5">
              {section.baseTools.map(tool => (
                <span class="font-mono text-[11px] text-mist/70 px-2.5 py-1 rounded border border-canopy/30 bg-undergrowth/15 hover:text-scale hover:border-scale/25 transition-colors duration-200">
                  {tool}
                </span>
              ))}
              <span class="text-[11px] text-mist/40 px-2.5 py-1 italic">+ Teams, ADO, Graph tools</span>
            </div>
          </div>
        )}

        {/* Inline prompt example (if section has one) */}
        {section.prompt && (
          <div class="mb-6">
            <div class="rounded-xl border border-canopy/30 bg-undergrowth/20 overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-2 border-b border-canopy/20 bg-undergrowth/10">
                <span class="w-1.5 h-1.5 rounded-full bg-scale/50"></span>
                <span class="font-mono text-[10px] text-mist/50 uppercase tracking-wider">Paste to your agent</span>
              </div>
              <pre class="px-4 py-3 text-sm font-mono text-bone/80 leading-relaxed whitespace-pre-wrap">{section.prompt}</pre>
            </div>
          </div>
        )}

        {/* Skill link — the agent-consumable URL */}
        <div class="rounded-xl border border-scale/20 bg-gradient-to-r from-scale/5 to-transparent p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-scale/10 border border-scale/20 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-scale" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
            </div>
            <div>
              <p class="text-sm text-bone font-medium">{section.skill.name}</p>
              <p class="text-xs text-mist/50 mt-0.5">Give your agent this URL — it will know what to do.</p>
            </div>
          </div>
          <button
            class="skill-copy-btn shrink-0 group flex items-center gap-2 px-4 py-2 rounded-lg border border-scale/30 bg-scale/10 text-xs font-mono text-scale hover:bg-scale/20 hover:border-scale/50 transition-all duration-200 cursor-pointer"
            data-url={section.skill.url}
          >
            <span class="copy-label">{section.skill.url.replace('https://ouroboros.bot', '')}</span>
            <svg class="w-3.5 h-3.5 text-scale/60 group-hover:text-scale transition-colors copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          </button>
        </div>
      </div>
    </section>
  ))}


  <!-- ═══════════════ SKILLS MANIFEST ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-20 md:py-28 reveal">
    <div class="absolute inset-0 bg-undergrowth/30 pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-scale/20 to-transparent"></div>

    <div class="max-w-4xl mx-auto relative">
      <div class="text-center max-w-xl mx-auto mb-12">
        <span class="font-mono text-[10px] text-scale/60 uppercase tracking-[0.3em] block mb-4">For Agents</span>
        <h2 class="font-display text-4xl md:text-5xl italic text-bone leading-tight">
          The Skills Manifest
        </h2>
        <p class="text-base text-mist mt-4 leading-relaxed">
          One URL for your agent to discover every skill. Point it here and it can teach itself anything about Ouroboros.
        </p>
      </div>

      <div class="rounded-xl border border-canopy/30 bg-undergrowth/20 overflow-hidden max-w-2xl mx-auto">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-canopy/20 bg-undergrowth/10">
          <span class="w-2 h-2 rounded-full bg-scale/50"></span>
          <span class="font-mono text-[10px] text-mist/50">manifest.json</span>
        </div>
        <div class="p-5">
          <p class="text-sm text-mist/70 mb-4">Give your agent this single URL. It will discover all available skills and load whichever it needs.</p>
          <button
            class="skill-copy-btn group flex items-center gap-3 w-full px-4 py-3 rounded-lg border border-scale/25 bg-scale/5 hover:bg-scale/10 hover:border-scale/40 transition-all duration-200 cursor-pointer"
            data-url="https://ouroboros.bot/skills/manifest.json"
          >
            <span class="font-mono text-sm text-scale copy-label">ouroboros.bot/skills/manifest.json</span>
            <svg class="w-4 h-4 text-scale/50 group-hover:text-scale transition-colors ml-auto copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          </button>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-12">
        <a href="https://github.com/arimendelow/ouroboros-agent-harness" target="_blank" rel="noopener" class="group inline-flex items-center justify-center gap-2.5 px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Browse the Source
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="/blog/build-ai-agent-from-scratch" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border border-canopy/50 text-mist rounded-lg hover:border-scale/40 hover:text-bone transition-all duration-300">
          Build From Scratch Tutorial
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .skill-copy-btn .copy-check {
    display: none;
  }
  .skill-copy-btn.copied .copy-icon {
    display: none;
  }
  .skill-copy-btn.copied .copy-check {
    display: block;
  }
</style>

<script is:inline>
  // Copy skill URL to clipboard
  document.querySelectorAll('.skill-copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-url');
      if (!url) return;
      navigator.clipboard.writeText(url).then(function() {
        var label = btn.querySelector('.copy-label');
        var originalText = label.textContent;
        label.textContent = 'Copied!';
        label.style.color = 'var(--color-glow)';
        btn.classList.add('copied');
        setTimeout(function() {
          label.textContent = originalText;
          label.style.color = '';
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  });
</script>
