---
import DocsPageShell from '../../components/DocsPageShell.astro'
import PromptCard from '../../components/PromptCard.astro'

const pages = [
  {
    href: '/docs/getting-started',
    title: 'Run one command. Talk to the serpent.',
    description: 'npx ouro.bot starts an interactive guide that walks you through provider setup, naming, and personality.',
    icon: '🐍',
  },
  {
    href: '/docs/bundles-and-psyche',
    title: 'Your agent has a portable self.',
    description: 'What lives in a bundle, what the psyche files are for, and how to ask your agent to inspect them.',
    icon: '◈',
  },
  {
    href: '/docs/continuity-and-memory',
    title: 'Keep the thread.',
    description: 'How agent-initiated memory, friend-scoped notes, and associative recall work together.',
    icon: '◉',
  },
  {
    href: '/docs/architecture',
    title: 'Understand the body.',
    description: 'Modules named like organs. A runtime the model can read, reason about, and extend.',
    icon: '♥',
  },
  {
    href: '/docs/skills-and-prompts',
    title: 'Hand work off cleanly.',
    description: 'Prompts for quick questions. Skill handoffs for tasks that need the latest local truth.',
    icon: '◆',
  },
  {
    href: '/what-is-an-agent-harness',
    title: 'Start from first principles.',
    description: 'What an agent harness is, why it matters, and how it differs from a framework.',
    icon: '◇',
  },
]
---

<DocsPageShell
  title="Ouroboros Docs | Guides for the TypeScript AI Agent Harness"
  description="Docs for the Ouroboros TypeScript AI agent harness: setup, continuity, psyche files, architecture, and prompts for humans and agents."
  eyebrow="Documentation"
  canonical="https://ouroboros.bot/docs/"
  intro="These pages help you place the object and choose the next question. For exact commands, file names, or runtime behavior — ask your agent for the live answer."
  noteTitle="Docs for humans, skills for agents"
  noteBody="The website explains the what. Your agent fetches the how from the code, the local install, or the bundle it's working inside."
>
  <section>
    <div class="grid md:grid-cols-2 gap-4">
      {pages.map((page) => (
        <a href={page.href} class="group flex items-start gap-5 rounded-xl border border-canopy/30 bg-undergrowth/20 p-6 transition-all duration-300 hover:border-scale/40 hover:bg-undergrowth/40">
          <span class="text-scale text-lg mt-0.5 shrink-0 group-hover:text-glow transition-colors">{page.icon}</span>
          <div>
            <h2 class="font-display text-xl md:text-2xl italic text-bone group-hover:text-scale transition-colors leading-snug">{page.title}</h2>
            <p class="mt-2 text-sm text-mist/70 leading-relaxed">{page.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section>
    <p class="font-display text-xl italic text-bone mb-4">Have a question?</p>
    <PromptCard
      prompt="Inspect the latest local Ouroboros install or repo on this machine and answer this using the current source of truth, not cached assumptions: [your question here]"
      footnote="Each docs page also has a more specific prompt. This one works for anything."
    />
  </section>
</DocsPageShell>
