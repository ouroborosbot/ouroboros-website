---
import DocsPageShell from '../../components/DocsPageShell.astro'

const pages = [
  {
    href: '/docs/getting-started',
    label: 'Getting Started',
    title: 'Prompt your way into the harness.',
    description: 'Use your agent as the operator from the first run instead of following a stale checklist by hand.',
  },
  {
    href: '/docs/bundles-and-psyche',
    label: 'Bundles And Psyche',
    title: 'Your agent has a portable self.',
    description: 'Learn what lives in a bundle, what the psyche files are for, and how to ask your agent to inspect them live.',
  },
  {
    href: '/docs/continuity-and-memory',
    label: 'Continuity And Memory',
    title: 'Keep the thread.',
    description: 'Ask your agent how continuity, notes, and memory work in the current install or repo instead of trusting fixed prose.',
  },
  {
    href: '/docs/architecture',
    label: 'Architecture',
    title: 'Understand the body.',
    description: 'Use the docs to place the parts, then have your agent inspect the live codebase for the exact answers.',
  },
  {
    href: '/docs/skills-and-prompts',
    label: 'Skills And Prompts',
    title: 'Hand work off cleanly.',
    description: 'Use prompts for simple questions and skill handoffs for deeper tasks that need the latest local truth.',
  },
  {
    href: '/what-is-an-agent-harness',
    label: 'What Is An Agent Harness?',
    title: 'Start from first principles.',
    description: 'Use the evergreen explainer if you need to place the category before you touch the operator docs.',
  },
]
---

<DocsPageShell
  title="Docs for humans. Skills for agents."
  description="These docs stay evergreen on purpose. For live commands, current internals, or implementation details, ask your agent to inspect the latest local install or repo."
  eyebrow="Documentation"
  canonical="https://ouroboros.bot/docs"
  intro="The website should help you place the object and choose the next question. Your agent should fetch the real-time answer from the code, the local install, or the bundle it is actually working inside."
  noteTitle="Operator rule"
  noteBody="If you need exact commands, tool lists, file names, or runtime behavior, ask your agent for the live answer instead of trusting a static page."
>
  <section>
    <div class="divide-y divide-canopy/30">
      {pages.map((page, i) => (
        <a href={page.href} class="group grid grid-cols-[3rem_1fr] gap-4 py-8 first:pt-0 last:pb-0 items-start">
          <span class="font-mono text-sm text-mist/30 group-hover:text-scale transition-colors">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h2 class="font-display text-2xl italic text-bone group-hover:text-scale transition-colors">{page.title}</h2>
            <p class="mt-2 text-sm text-mist/60 leading-relaxed">{page.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="grid gap-12 lg:grid-cols-2">
    <div>
      <p class="font-display text-xl italic text-bone">How to use this section</p>
      <ol class="mt-4 space-y-3 text-sm leading-7 text-mist list-decimal pl-5">
        <li>Use the page to understand the concept and pick your next question.</li>
        <li>Paste the sample prompt into your agent for the current, machine-specific answer.</li>
        <li>If the job is deeper, point your agent at the matching skill and tell it to inspect the live code or bundle before acting.</li>
      </ol>
    </div>

    <div>
      <p class="font-display text-xl italic text-bone">Default prompt</p>
      <pre class="mt-4 whitespace-pre-wrap font-mono text-sm leading-7 text-bone/85">Inspect the latest local Ouroboros install or repo on this machine and answer this using the current source of truth, not cached assumptions: [replace with your question]. If there is any ambiguity, tell me what you checked.</pre>
    </div>
  </section>
</DocsPageShell>
