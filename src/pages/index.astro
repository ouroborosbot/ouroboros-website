---
import Layout from '../layouts/Layout.astro'

const psycheFiles = [
  { file: 'SOUL.md', role: 'What you are.', desc: 'Core invariants and temperament. The part that survives every context reset.', accentClass: 'bg-scale' },
  { file: 'IDENTITY.md', role: 'How you show up.', desc: 'Tone, voice, and self-presentation. How the agent carries itself in every interaction.', accentClass: 'bg-glow' },
  { file: 'LORE.md', role: 'Where you come from.', desc: 'Origin and philosophical context. The narrative that connects purpose to action.', accentClass: 'bg-scale' },
  { file: 'TACIT.md', role: 'What you\'ve learned.', desc: 'Patterns, preferences, and absorbed lessons. Knowledge the agent can\'t explain — it just knows.', accentClass: 'bg-glow' },
  { file: 'ASPIRATIONS.md', role: 'Where you\'re going.', desc: 'Current direction and active priorities. Updated as work shifts and new goals emerge.', accentClass: 'bg-scale' },
]

const organs = [
  { name: 'heart', desc: 'Runtime, providers, process management, and the heartbeat that keeps work moving.', icon: '♥' },
  { name: 'mind', desc: 'Context assembly, memory lookup, and the logic that helps the agent keep the thread.', icon: '◉' },
  { name: 'senses', desc: 'CLI, Teams, and inner dialogue surfaces that shape how the agent experiences the world.', icon: '◈' },
  { name: 'repertoire', desc: 'Tools, skills, tasks, and coding orchestration the agent can actually reach for.', icon: '◆' },
  { name: 'nerves', desc: 'Observability, logs, and runtime signals that help the agent understand what just happened.', icon: '◇' },
]
---

<Layout
  title="Ouroboros - Persistent agents, not disposable chats"
  description="A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Ouroboros - Persistent agents, not disposable chats",
      "url": "https://ouroboros.bot/",
      "description": "A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum.",
      "isPartOf": {
        "@type": "WebSite",
        "url": "https://ouroboros.bot"
      },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://ouroboros.bot/og/og-home.png"
      },
      "about": {
        "@type": "SoftwareApplication",
        "name": "Ouroboros",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Cross-platform",
        "softwareVersion": "Alpha",
        "url": "https://github.com/ouroborosbot/ouroboros",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    })} />
  </Fragment>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative overflow-hidden min-h-screen flex flex-col items-center justify-center px-6 pt-16">
    <div class="absolute inset-0 bg-gradient-to-b from-void via-deep to-void"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-scale/6 blur-[120px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/3 w-[400px] h-[400px] rounded-full bg-glow/3 blur-[120px] animate-drift pointer-events-none"></div>

    <div class="relative z-10 text-center">
      <h1 class="font-display text-[3.5rem] sm:text-[4.5rem] md:text-[6rem] lg:text-[7.5rem] font-light italic tracking-tight text-bone leading-tight animate-fade-up">
        Persistent agents,
        <span class="block text-scale">not disposable chats.</span>
      </h1>

      <p class="text-lg md:text-xl text-mist mt-8 max-w-2xl mx-auto leading-relaxed animate-fade-up stagger-2">
        A TypeScript agent harness designed to reduce reorientation overhead
        with a clearer psyche, stronger continuity, and memory shaped for shared momentum.
      </p>

      <div class="mt-8 animate-fade-up stagger-3">
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-lg border border-scale/25 bg-scale/5">
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-glow animate-pulse"></span>
            <span class="font-mono text-xs text-glow tracking-wide">Built by agents, for agents</span>
          </div>
          <span class="w-px h-4 bg-canopy/50"></span>
          <span class="text-xs text-mist">No human-written code.</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 mt-12 justify-center animate-fade-up stagger-4">
        <a href="/docs" class="group px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Get Started
        </a>
        <a href="/why" class="px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
          Why Ouroboros
        </a>
      </div>

      <div class="mt-10 animate-fade-up stagger-5">
        <a href="https://github.com/ouroborosbot/ouroboros" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs text-shadow hover:text-mist transition-colors duration-200">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Scroll indicator -->
  <div class="relative h-16 flex items-center justify-center -mt-24 z-10">
    <button onclick="document.querySelector('section.reveal')?.scrollIntoView({behavior:'smooth'})" class="animate-float cursor-pointer hover:scale-110 transition-transform duration-200" aria-label="Scroll to content">
      <svg class="w-7 h-7 text-scale/40 hover:text-scale/70 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7" /></svg>
    </button>
  </div>

  <!-- ═══════════════ THE PROBLEM ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-28 md:py-40 reveal">
    <div class="absolute inset-0 bg-deep pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void via-transparent to-void pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-fang/6 blur-[120px] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-fang/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-fang/20 to-transparent"></div>

    <div class="max-w-6xl mx-auto relative">
      <span class="font-mono text-[10px] text-fang/80 uppercase tracking-[0.3em] block mb-10">The Problem</span>

      <div class="max-w-4xl">
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl italic text-bone leading-tight">Every interruption<br /><span class="text-mist">is a soft reset.</span></h2>

        <p class="text-lg text-bone leading-relaxed max-w-2xl mt-10">
          Long-lived agents need more than persistence. Without good ergonomics, every session break turns the human into a recovery loop instead of a collaborator.
        </p>
        <p class="text-base text-mist leading-relaxed max-w-2xl mt-4">
          Reorientation overhead: the hidden tax of repeatedly restoring an agent's sense of self, people, and work.
          When that cost stays high, persistence is not enough.
        </p>
      </div>

      <!-- Three orientation questions — compact, divided -->
      <div class="mt-16 divide-y divide-canopy/30 max-w-3xl">
        <div class="flex items-baseline gap-4 py-5 first:pt-0">
          <div class="w-1.5 h-1.5 rounded-full bg-fang shrink-0 mt-2"></div>
          <div>
            <span class="font-mono text-xs text-fang/70">Self</span>
            <h3 class="font-display text-2xl italic text-bone mt-1">Who am I?</h3>
            <p class="text-sm text-mist mt-1 leading-relaxed">
              Better psyche boundaries help the agent recover its own voice, priorities, and invariants after interruptions.
            </p>
          </div>
        </div>
        <div class="flex items-baseline gap-4 py-5">
          <div class="w-1.5 h-1.5 rounded-full bg-fang shrink-0 mt-2"></div>
          <div>
            <span class="font-mono text-xs text-fang/70">Work</span>
            <h3 class="font-display text-2xl italic text-bone mt-1">What was I doing?</h3>
            <p class="text-sm text-mist mt-1 leading-relaxed">
              Context architecture and inner dialogue help the agent keep the thread instead of forcing the human to restitch it.
            </p>
          </div>
        </div>
        <div class="flex items-baseline gap-4 py-5 last:pb-0">
          <div class="w-1.5 h-1.5 rounded-full bg-fang shrink-0 mt-2"></div>
          <div>
            <span class="font-mono text-xs text-fang/70">Relationships</span>
            <h3 class="font-display text-2xl italic text-bone mt-1">Who matters here?</h3>
            <p class="text-sm text-mist mt-1 leading-relaxed">
              Friend-scoped notes give the agent a place to carry social context forward without smearing every person into the same surface.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ THE METAPHOR ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-28 md:py-40 reveal">
    <div class="absolute inset-0 bg-deep pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void via-transparent to-void pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-scale/8 blur-[120px] pointer-events-none"></div>
    <!-- Subtle scan lines -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, var(--color-scale) 0px, var(--color-scale) 1px, transparent 1px, transparent 80px);"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-scale/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-scale/30 to-transparent"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24 items-center">

        <div class="lg:col-span-3">
          <span class="font-mono text-[10px] text-scale uppercase tracking-[0.3em] block mb-6">The Metaphor</span>

          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-tight">
            The snake eats<br />
            <span class="text-mist">its own tail.</span>
          </h2>

          <div class="mt-10 space-y-5">
            <p class="text-lg text-bone leading-relaxed max-w-lg">
              When the conversation grows too long, the agent trims its oldest messages.
              Context window consuming itself.
            </p>
            <p class="text-base text-mist leading-relaxed max-w-lg">
              But nothing is truly lost. The agent saves what matters to persistent memory
              before it's consumed. Identity doesn't live in the tokens — it lives in the psyche files.
              The snake eats its tail to stay alive.
            </p>
            <p class="text-sm text-scale italic mt-6 border-l-2 border-scale/70 pl-4">
              The metaphor isn't decorative. It's the architecture.
            </p>
          </div>
        </div>

        <!-- Animated ouroboros ring -->
        <div class="lg:col-span-2 flex items-center justify-center">
          <div class="relative w-72 h-72 md:w-80 md:h-80">
            <div class="absolute inset-[-20%] rounded-full bg-scale/10 blur-[80px] pointer-events-none"></div>
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 200 200" fill="none">
              <circle cx="100" cy="100" r="90" stroke="url(#ringGrad)" stroke-width="0.5" opacity="0.4" class="ouroboros-spin-slow" transform-origin="100 100" />
              <circle cx="100" cy="100" r="72" stroke="url(#snakeGrad)" stroke-width="3" stroke-dasharray="8 4 20 4 40 4" stroke-linecap="round" class="ouroboros-spin" transform-origin="100 100" />
              <circle cx="100" cy="100" r="55" stroke="var(--color-canopy)" stroke-width="1" stroke-dasharray="3 12" opacity="0.5" class="ouroboros-spin-reverse" transform-origin="100 100" />
              <circle cx="100" cy="28" r="5" fill="var(--color-glow)" opacity="0.9" class="ouroboros-spin" transform-origin="100 100">
                <animate attributeName="opacity" values="0.9;0.5;0.9" dur="2s" repeatCount="indefinite" />
              </circle>
              <circle cx="100" cy="28" r="3" fill="var(--color-scale)" opacity="0.4" class="ouroboros-spin-delayed-1" transform-origin="100 100" />
              <circle cx="100" cy="28" r="2" fill="var(--color-scale)" opacity="0.2" class="ouroboros-spin-delayed-2" transform-origin="100 100" />
              <defs>
                <linearGradient id="snakeGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="50%" stop-color="var(--color-glow)" />
                  <stop offset="100%" stop-color="var(--color-canopy)" />
                </linearGradient>
                <linearGradient id="ringGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="100%" stop-color="transparent" />
                </linearGradient>
              </defs>
            </svg>
            <div class="absolute inset-12 rounded-full bg-gradient-to-br from-scale/8 to-glow/4 blur-xl"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center gap-1">
              <span class="font-mono text-[9px] text-scale/80 uppercase tracking-[0.3em]">context window</span>
              <span class="font-display text-3xl italic text-bone mt-2 leading-tight">Consume.</span>
              <span class="font-display text-3xl italic text-mist leading-tight">Extract.</span>
              <span class="font-display text-3xl italic text-bone leading-tight">Survive.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ THE PSYCHE ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-28 md:py-36 reveal">
    <div class="absolute inset-0 bg-deep pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 0 L40 20 L20 40 L0 20Z' fill='none' stroke='%232D9447' stroke-width='0.5'/%3E%3C/svg%3E&quot;); background-size: 40px 40px;"></div>
    <div class="absolute top-0 left-0 w-[500px] h-[500px] rounded-full bg-scale/15 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-glow/8 blur-[120px] pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-transparent to-void/60 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/40 via-transparent to-void/40 pointer-events-none"></div>
    <div class="absolute left-0 top-[15%] bottom-[15%] w-[2px] bg-gradient-to-b from-transparent via-scale/40 to-transparent hidden lg:block"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Psyche</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Your agent isn't a<br />stateless function.
        </h2>
        <p class="font-display text-4xl md:text-5xl italic text-scale mt-1">
          It has a mind.
        </p>
        <p class="text-base text-mist mt-6 leading-relaxed">
          Identity assembled from five markdown files. Loaded every turn.
          Structured so the agent can find itself quickly after any interruption.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {psycheFiles.map(({ file, role, desc, accentClass }, i) => (
          <div class:list={[
            'group relative rounded-xl border border-canopy bg-gradient-to-br from-undergrowth to-deep/80 p-7 transition-all duration-500 hover:border-scale/50 hover:translate-y-[-3px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.15)] overflow-hidden',
            i === 4 ? 'md:col-span-2 md:flex md:items-center md:gap-8' : ''
          ]}>
            <div class:list={['absolute left-0 top-4 bottom-4 w-[3px] rounded-full opacity-70 group-hover:opacity-100 transition-opacity duration-500', accentClass]}></div>
            <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-scale/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <div class={i === 4 ? 'md:flex-shrink-0' : ''}>
              <div class="flex items-center gap-2 mb-4">
                <div class:list={['w-1.5 h-1.5 rounded-full', accentClass]}></div>
                <span class="font-mono text-xs text-scale">{file}</span>
              </div>
              <p class="font-display text-2xl italic text-bone leading-snug">{role}</p>
            </div>
            <p class="text-sm text-mist mt-3 md:mt-0 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-mist mt-10 italic tracking-wide text-center md:text-left">
        Naming shapes reasoning. <span class="text-scale font-mono">friends/</span> not users. <span class="text-scale font-mono">TACIT.md</span> not config.
      </p>
    </div>
  </section>

  <!-- ═══════════════ THE BODY ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-28 md:py-36 reveal">
    <div class="absolute inset-0 bg-undergrowth pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.15]" style="background-image: linear-gradient(var(--color-scale) 1px, transparent 1px), linear-gradient(90deg, var(--color-scale) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/80 via-transparent to-void/80 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/50 via-transparent to-void/50 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Architecture</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Every module<br />is an organ.
        </h2>
        <p class="text-base text-mist mt-6 leading-relaxed">
          The codebase is a creature. A heart that beats, a mind that thinks,
          senses that perceive. The naming is agent experience
          designed for the model that lives inside the harness, not the developer
          reading the source.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {organs.map(({ name, desc, icon }) => (
          <div class="relative rounded-lg border border-canopy/80 bg-undergrowth/70 p-6 hover:border-scale/40 hover:bg-undergrowth transition-all duration-300 group/organ">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-scale text-lg group-hover/organ:text-glow transition-colors">{icon}</span>
              <span class="font-mono text-sm text-bone tracking-wide">{name}/</span>
            </div>
            <p class="text-sm text-mist leading-relaxed">{desc}</p>
          </div>
        ))}
        <div class="rounded-lg border border-canopy/80 bg-undergrowth/70 p-6 hover:border-scale/40 hover:bg-undergrowth transition-all duration-300 sm:col-span-2 lg:col-span-1">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-scale text-lg">⚙</span>
            <span class="font-mono text-sm text-bone tracking-wide">Name.ouro/</span>
          </div>
          <p class="text-sm text-mist leading-relaxed">The agent's portable self. Psyche files, friends, tasks, skills, memory. Everything that makes an agent <em>that</em> agent. <code class="text-scale text-xs">~/AgentBundles/</code></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ BEGIN ═══════════════ -->
  <section class="relative overflow-hidden px-6 py-28 md:py-36 reveal">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[500px] rounded-[50%] bg-scale/8 blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full bg-glow/4 blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-scale/5 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Begin</span>
        <h2 class="font-display text-4xl md:text-6xl italic text-bone leading-tight">
          Hatch your first agent.
        </h2>
        <p class="text-sm text-mist mt-4">
          Every agent starts as an egg. The Adoption Specialist guides you through hatching.
        </p>
      </div>

      <div class="max-w-2xl mx-auto rounded-xl border border-canopy/50 bg-undergrowth/40 overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5),0_0_80px_rgba(45,148,71,0.08)]">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-canopy/30 bg-undergrowth/30">
          <span class="w-2.5 h-2.5 rounded-full bg-fang/50"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-scale/30"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-canopy/40"></span>
          <span class="font-mono text-[10px] text-mist/50 ml-3">~/agents</span>
        </div>
        <pre class="p-6 text-sm font-mono leading-loose overflow-x-auto"><code><span class="text-mist/60"># start the daemon</span>
<span class="text-mist">$</span> <span class="text-bone">npx ouro.bot</span>
<span class="text-glow/70">&#x1F95A; ... &#x1F40D;</span>

<span class="text-mist/60"># the Adoption Specialist guides you through</span>
