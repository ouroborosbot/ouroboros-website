---
import Layout from '../layouts/Layout.astro'

const providers = ['Anthropic', 'Azure OpenAI', 'OpenAI Codex', 'MiniMax']

const psycheFiles = [
  { file: 'SOUL.md', role: 'What you are.', desc: 'Core invariants and temperament. The part that survives every context reset.', accentClass: 'bg-scale' },
  { file: 'IDENTITY.md', role: 'How you show up.', desc: 'Tone, voice, self-awareness. The face your agent wears in every conversation.', accentClass: 'bg-glow' },
  { file: 'LORE.md', role: 'Where you come from.', desc: 'Origin story and philosophical context. The narrative that gives purpose to action.', accentClass: 'bg-scale' },
  { file: 'FRIENDS.md', role: 'Who you know.', desc: 'Relationships and social context. Not user IDs — friends. Partner, not user.', accentClass: 'bg-glow' },
  { file: 'TACIT.md', role: 'What you\'ve learned.', desc: 'Preferences, patterns, lessons absorbed over time. The knowledge you can\'t explain — you just know.', accentClass: 'bg-scale' },
]

const organs = [
  { name: 'heart', desc: 'The agent loop. Streaming, provider adapters, self-correction. The beat that keeps everything alive.', icon: '♥' },
  { name: 'mind', desc: 'System prompt assembly. Sliding context window. Memory extraction before consumption.', icon: '◉' },
  { name: 'senses', desc: 'Channel adapters. CLI with spinners. Teams bot with streaming cards. How your agent perceives.', icon: '◈' },
  { name: 'repertoire', desc: 'Tools, skills, commands, API clients. Everything your agent can reach for.', icon: '◆' },
  { name: 'wardrobe', desc: 'Formatting, loading phrases, presentation layer. How your agent dresses its words.', icon: '◇' },
]
---

<Layout title="Ouroboros — Build agents that know who they are" description="A zero-dependency TypeScript framework for AI agents that self-modify, remember, and grow. Psyche files, sliding context windows, and creature-body architecture.">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center px-6 overflow-hidden">
    <!-- Atmospheric layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-void via-deep to-void"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-scale/6 blur-[200px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/3 w-[400px] h-[400px] rounded-full bg-glow/3 blur-[250px] animate-drift pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent"></div>

    <div class="relative z-10 text-center">
      <h1 class="font-display text-[4rem] sm:text-[5.5rem] md:text-[8rem] lg:text-[12rem] font-light italic tracking-tight text-bone leading-[0.85] animate-fade-up">
        ouroboros
      </h1>

      <p class="text-xl md:text-2xl text-mist/80 font-light mt-8 animate-fade-up stagger-2 tracking-wide">
        Build agents that know who they are.
      </p>

      <p class="text-sm text-mist/70 mt-5 max-w-md mx-auto leading-relaxed animate-fade-up stagger-3">
        A zero-dependency TypeScript harness for AI agents that self-modify,
        remember, and grow. Born from a lobster's molt. Open source.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-12 justify-center animate-fade-up stagger-4">
        <a href="/docs" class="group px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Get Started
        </a>
        <a href="/blog/build-ai-agent-from-scratch" class="px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
          How Agents Work
        </a>
      </div>
    </div>
  </section>


  <!-- Section divider -->
  <div class="relative h-24 flex items-center justify-center">
    <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-scale/25 to-transparent"></div>
    <div class="w-2 h-2 rounded-full bg-scale/40 relative z-10 shadow-[0_0_12px_rgba(45,148,71,0.3)]"></div>
  </div>

  <!-- ═══════════════ THE METAPHOR ═══════════════ -->
  <section class="relative px-6 py-28 md:py-40 reveal overflow-hidden">
    <!-- Lifted background for visual separation -->
    <div class="absolute inset-0 bg-undergrowth/70 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void/60 via-transparent to-void/60 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-scale/10 blur-[250px] pointer-events-none"></div>
    <!-- Vertical accent -->
    <div class="absolute right-12 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-scale/20 to-transparent hidden lg:block"></div>

    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24 items-center">

        <!-- Text: 3 cols -->
        <div class="lg:col-span-3">
          <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Metaphor</span>

          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-[1.05]">
            The snake eats<br />
            <span class="text-mist/80">its own tail.</span>
          </h2>

          <div class="mt-10 space-y-5">
            <p class="text-lg text-mist leading-relaxed max-w-lg">
              When the conversation grows too long, the agent trims its oldest messages.
              Context window consuming itself.
            </p>
            <p class="text-base text-mist leading-relaxed max-w-lg">
              But nothing is truly lost. Facts are extracted to memory before they're
              consumed. Identity doesn't live in the tokens — it lives in the psyche files.
              The snake eats its tail to stay alive.
            </p>
            <p class="text-sm text-mist/70 italic mt-6 border-l-2 border-scale/40 pl-4">
              The metaphor isn't decorative. It's the architecture.
            </p>
          </div>
        </div>

        <!-- Visual: 2 cols — ouroboros SVG -->
        <div class="lg:col-span-2 flex items-center justify-center">
          <div class="relative w-72 h-72 md:w-80 md:h-80">
            <!-- Animated ouroboros ring -->
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 200 200" fill="none">
              <!-- Outer glow ring -->
              <circle cx="100" cy="100" r="90" stroke="url(#ringGrad)" stroke-width="0.5" opacity="0.3" style="animation: spin 80s linear infinite;" transform-origin="100 100" />
              <!-- Main snake ring — dashed to suggest segments being consumed -->
              <circle cx="100" cy="100" r="72" stroke="url(#snakeGrad)" stroke-width="2.5" stroke-dasharray="8 4 20 4 40 4" stroke-linecap="round" style="animation: spin 25s linear infinite;" transform-origin="100 100" />
              <!-- Inner consumption ring — reverse spin -->
              <circle cx="100" cy="100" r="55" stroke="var(--color-canopy)" stroke-width="0.8" stroke-dasharray="3 12" opacity="0.4" style="animation: spin 40s linear infinite reverse;" transform-origin="100 100" />
              <!-- Snake head dot -->
              <circle cx="100" cy="28" r="4" fill="var(--color-scale)" opacity="0.9" style="animation: spin 25s linear infinite;" transform-origin="100 100">
                <animate attributeName="opacity" values="0.9;0.5;0.9" dur="2s" repeatCount="indefinite" />
              </circle>
              <!-- Tail fade dots -->
              <circle cx="100" cy="28" r="2.5" fill="var(--color-scale)" opacity="0.3" style="animation: spin 25s linear infinite; animation-delay: -0.8s;" transform-origin="100 100" />
              <circle cx="100" cy="28" r="1.5" fill="var(--color-scale)" opacity="0.15" style="animation: spin 25s linear infinite; animation-delay: -1.6s;" transform-origin="100 100" />
              <defs>
                <linearGradient id="snakeGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="50%" stop-color="var(--color-glow)" />
                  <stop offset="100%" stop-color="var(--color-canopy)" />
                </linearGradient>
                <linearGradient id="ringGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="100%" stop-color="transparent" />
                </linearGradient>
              </defs>
            </svg>
            <!-- Inner glow -->
            <div class="absolute inset-12 rounded-full bg-gradient-to-br from-scale/6 to-glow/3 blur-xl"></div>
            <!-- Core text -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center gap-1">
              <span class="font-mono text-[9px] text-scale/60 uppercase tracking-[0.3em]">context window</span>
              <span class="font-display text-3xl italic text-bone mt-2 leading-tight">Consume.</span>
              <span class="font-display text-3xl italic text-mist/70 leading-tight">Extract.</span>
              <span class="font-display text-3xl italic text-bone leading-tight">Survive.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Section divider -->
  <div class="relative h-24 flex items-center justify-center">
    <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent"></div>
  </div>

  <!-- ═══════════════ THE PSYCHE ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <!-- Radial glow from top-left -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] rounded-full bg-scale/8 blur-[200px] pointer-events-none"></div>
    <!-- Diagonal accent stripe -->
    <div class="absolute -left-32 top-1/4 w-[600px] h-px bg-gradient-to-r from-transparent via-canopy/30 to-transparent rotate-[25deg] pointer-events-none"></div>
    <!-- Subtle left accent bar -->
    <div class="absolute left-0 top-[15%] bottom-[15%] w-[2px] bg-gradient-to-b from-transparent via-scale/25 to-transparent hidden lg:block"></div>
    <div class="max-w-6xl mx-auto">
      <!-- Header — offset left -->
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Psyche</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Your agent isn't a<br />stateless function.
        </h2>
        <p class="font-display text-4xl md:text-5xl italic text-scale/70 mt-1">
          It has a mind.
        </p>
        <p class="text-base text-mist/80 mt-6 leading-relaxed">
          Personality assembled from five markdown files. Loaded every turn.
          And it develops over time — the psyche grows with the agent.
        </p>
      </div>

      <!-- Cards — 2x2 + spanning 5th card -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {psycheFiles.map(({ file, role, desc, accentClass }, i) => (
          <div class:list={[
            'group relative rounded-xl border border-canopy/80 bg-gradient-to-br from-undergrowth/80 to-deep p-7 transition-all duration-500 hover:border-scale/50 hover:translate-y-[-3px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.15)] overflow-hidden',
            i === 4 ? 'md:col-span-2 md:flex md:items-center md:gap-8' : ''
          ]}>
            <!-- Left accent bar -->
            <div class:list={['absolute left-0 top-4 bottom-4 w-[2px] rounded-full opacity-60 group-hover:opacity-100 transition-opacity duration-500', accentClass]}></div>
            <!-- Corner glow -->
            <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-scale/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <!-- File tab -->
            <div class={i === 4 ? 'md:flex-shrink-0' : ''}>
              <div class="flex items-center gap-2 mb-4">
                <div class:list={['w-1.5 h-1.5 rounded-full', accentClass]}></div>
                <span class="font-mono text-xs text-scale/70">{file}</span>
              </div>
              <p class="font-display text-2xl italic text-bone leading-snug">{role}</p>
            </div>
            <p class="text-sm text-mist/85 mt-3 md:mt-0 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-mist/60 mt-8 italic tracking-wide">
        "Partner, not user." — FRIENDS.md replaces USER.md.
      </p>
    </div>
  </section>


  <!-- Section divider -->
  <div class="relative h-24 flex items-center justify-center">
    <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-scale/25 to-transparent"></div>
    <div class="w-2 h-2 rounded-full bg-scale/40 relative z-10 shadow-[0_0_12px_rgba(45,148,71,0.3)]"></div>
  </div>

  <!-- ═══════════════ THE BODY ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <!-- Lifted background -->
    <div class="absolute inset-0 bg-undergrowth/60 pointer-events-none"></div>
    <!-- Blueprint grid background -->
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(var(--color-scale) 1px, transparent 1px), linear-gradient(90deg, var(--color-scale) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Fade edges of grid -->
    <div class="absolute inset-0 bg-gradient-to-b from-void/90 via-transparent to-void/90 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/60 via-transparent to-void/60 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Architecture</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Every module<br />is an organ.
        </h2>
        <p class="text-base text-mist/80 mt-6 leading-relaxed">
          The codebase is a creature. A heart that beats, a mind that thinks,
          senses that perceive. The naming isn't whimsy — it's how the model
          understands its own body.
        </p>
      </div>

      <!-- Organ specimens -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {organs.map(({ name, desc, icon }) => (
          <div class="relative rounded-lg border border-canopy/60 bg-undergrowth/50 p-6 hover:border-scale/40 hover:bg-undergrowth/80 transition-all duration-300 group/organ">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-scale/70 text-base group-hover/organ:text-scale transition-colors">{icon}</span>
              <span class="font-mono text-sm text-bone tracking-wide">{name}/</span>
            </div>
            <p class="text-sm text-mist/85 leading-relaxed">{desc}</p>
          </div>
        ))}
        <!-- Extra cell: the daemon -->
        <div class="rounded-lg border border-canopy/60 bg-undergrowth/50 p-6 hover:border-scale/40 hover:bg-undergrowth/80 transition-all duration-300 sm:col-span-2 lg:col-span-1">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-scale/70 text-base">⚙</span>
            <span class="font-mono text-sm text-bone tracking-wide">daemon/</span>
          </div>
          <p class="text-sm text-mist/85 leading-relaxed">Process manager, cron scheduler, health monitor. The nervous system that keeps agents alive. <code class="text-scale/80 text-xs">ouro status</code></p>
        </div>
      </div>

      <!-- Providers -->
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <span class="font-mono text-[10px] text-mist/60 uppercase tracking-[0.2em] mr-2">Providers</span>
        {providers.map(name => (
          <span class="text-xs text-mist/80 border border-canopy/50 rounded-full px-4 py-1.5 transition-colors duration-200 hover:border-scale/40 hover:text-bone">
            {name}
          </span>
        ))}
        <span class="text-xs text-mist/60 italic">+ extensible</span>
      </div>
    </div>
  </section>


  <!-- Section divider -->
  <div class="relative h-24 flex items-center justify-center">
    <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent"></div>
  </div>

  <!-- ═══════════════ SELF-PERPETUATION ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-undergrowth/30 to-transparent pointer-events-none"></div>
    <!-- Central convergence glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-glow/5 blur-[180px] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Seed</span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-tight">
          Your agent<br />improves itself.
        </h2>
        <p class="text-base text-mist/80 mt-6 leading-relaxed max-w-lg mx-auto">
          The reflection engine reads the agent's own architecture. Finds gaps.
          Writes code. Tests pass. PR merges. The snake grows. Then it does it again.
        </p>
      </div>

      <!-- The loop — continuous flow -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Connecting line -->
        <div class="absolute top-5 sm:top-7 left-[10%] right-[10%] h-px bg-gradient-to-r from-scale/10 via-scale/50 to-scale/10 hidden sm:block"></div>

        <div class="grid grid-cols-1 sm:grid-cols-5 gap-6 sm:gap-2">
          {(['Reflect', 'Plan', 'Build', 'Merge', 'Repeat'] as const).map((label, i) => {
            const descs = [
              'Read its own architecture. Find what\'s missing.',
              'Concrete steps. Not vague ideas.',
              'Write code. Run tests. Fix what breaks.',
              'PR. CI green. Land on main.',
              'Loop back. The snake is bigger now.',
            ]
            return (
              <div class="relative group flex sm:flex-col items-center sm:items-center gap-4 sm:gap-0 sm:text-center">
                <!-- Step circle -->
                <div class="relative z-10 w-12 h-12 sm:w-14 sm:h-14 shrink-0 rounded-full border border-canopy/60 bg-undergrowth/50 flex items-center justify-center group-hover:border-scale/60 transition-all duration-300 group-hover:shadow-[0_0_24px_rgba(45,148,71,0.25)] group-hover:bg-undergrowth/80">
                  <span class="font-mono text-xs text-scale group-hover:text-glow transition-colors">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div class="sm:mt-5">
                  <p class="font-display text-xl italic text-bone">{label}</p>
                  <p class="text-xs text-mist/85 mt-1.5 sm:mt-2.5 leading-relaxed max-w-[160px] mx-auto">{descs[i]}</p>
                </div>
              </div>
            )
          })}
        </div>
      </div>

      <p class="text-center text-xs text-mist/60 mt-12 tracking-wide">
        1730 tests · 100% coverage · every improvement ships verified
      </p>
    </div>
  </section>


  <!-- Section divider -->
  <div class="relative h-24 flex items-center justify-center">
    <div class="absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-scale/25 to-transparent"></div>
    <div class="w-2 h-2 rounded-full bg-scale/40 relative z-10 shadow-[0_0_12px_rgba(45,148,71,0.3)]"></div>
  </div>

  <!-- ═══════════════ HATCHING ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <!-- Bottom glow for the terminal -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full bg-scale/4 blur-[150px] pointer-events-none"></div>
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Begin</span>
        <h2 class="font-display text-4xl md:text-6xl italic text-bone leading-tight">
          Hatch your first agent.
        </h2>
        <p class="text-sm text-mist/85 mt-4">
          Every agent starts as an egg. A directory with a psyche and a purpose.
        </p>
      </div>

      <!-- Terminal -->
      <div class="max-w-2xl mx-auto rounded-xl border border-canopy/50 bg-undergrowth/40 overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5),0_0_80px_rgba(45,148,71,0.08)]">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-canopy/30 bg-undergrowth/30">
          <span class="w-2.5 h-2.5 rounded-full bg-fang/50"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-scale/30"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-canopy/40"></span>
          <span class="font-mono text-[10px] text-mist/50 ml-3">~/agents</span>
        </div>
        <pre class="p-6 text-sm font-mono leading-loose overflow-x-auto"><code><span class="text-mist/60"># hatch your agent</span>
<span class="text-mist">$</span> <span class="text-bone">ouro hatch my-agent</span>
<span class="inline-block px-2 py-0.5 text-[9px] uppercase tracking-wider border border-scale/25 rounded text-scale/50">coming soon</span>

<span class="text-mist/60"># or create by hand</span>
<span class="text-mist">$</span> <span class="text-bone">mkdir -p my-agent/psyche</span>

<span class="text-bone">my-agent/</span>
  <span class="text-mist">agent.json</span>         <span class="text-mist/60"># name, provider, config</span>
  <span class="text-mist">psyche/</span>
    <span class="text-glow/70">SOUL.md</span>          <span class="text-mist/60"># what you are</span>
    <span class="text-glow/70">IDENTITY.md</span>      <span class="text-mist/60"># how you show up</span>
    <span class="text-glow/70">LORE.md</span>          <span class="text-mist/60"># where you come from</span>
    <span class="text-glow/70">FRIENDS.md</span>       <span class="text-mist/60"># who you know</span>

<span class="text-mist">$</span> <span class="text-bone">npm run dev -- --agent my-agent</span></code></pre>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-12">
        <a href="/docs" class="group inline-flex items-center justify-center gap-2.5 px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Read the Docs
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="/story" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border border-canopy/50 text-mist rounded-lg hover:border-scale/40 hover:text-bone transition-all duration-300">
          How We Got Here
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
