---
import Layout from '../layouts/Layout.astro'

const pillars = [
  {
    label: 'Self',
    title: 'A cleaner psyche.',
    description: 'Five psyche files separate invariants, voice, origin, tacit knowledge, and active direction so the agent can find itself quickly.',
    payoff: 'Less identity drift.',
  },
  {
    label: 'Work',
    title: 'Context that keeps the thread.',
    description: 'Inner dialogue, continuity across sessions, and context architecture designed to preserve orientation instead of forcing constant resets.',
    payoff: 'Less re-briefing.',
  },
  {
    label: 'Relationships',
    title: 'Memory that respects people.',
    description: 'Quick friend-scoped notes make social context easier to carry forward without turning every detail into one giant shared blob.',
    payoff: 'Fewer lost relationships.',
  },
]

const body = [
  { name: 'heart', role: 'The loop', desc: 'Runtime, providers, process management, and the heartbeat that keeps work moving.' },
  { name: 'mind', role: 'Orientation', desc: 'Context assembly, memory lookup, and the logic that helps the agent keep the thread.' },
  { name: 'senses', role: 'Perception', desc: 'CLI, Teams, and inner dialogue surfaces that shape how the agent experiences the world.' },
  { name: 'repertoire', role: 'Action', desc: 'Tools, skills, tasks, and coding orchestration the agent can actually reach for.' },
  { name: 'nerves', role: 'Feedback', desc: 'Observability, logs, and runtime signals that help the agent understand what just happened.' },
]

const psyche = [
  { name: 'SOUL.md', role: 'Core invariants' },
  { name: 'IDENTITY.md', role: 'Voice and self-presentation' },
  { name: 'LORE.md', role: 'Origin and context' },
  { name: 'TACIT.md', role: 'Patterns and learned preferences' },
  { name: 'ASPIRATIONS.md', role: 'Current direction' },
]

const routes = [
  {
    href: '/why',
    label: 'Why Ouroboros',
    title: 'Agent ergonomics, not feature checklists.',
    description: 'Read the argument for why persistent agents need better orientation, less recovery overhead, and more shared momentum.',
  },
  {
    href: '/blog/what-is-agent-experience',
    label: 'What Is Agent Experience?',
    title: 'The category lens.',
    description: 'See why AX belongs beside UX and DX, and why good systems are shaped from the agent\'s point of view too.',
  },
  {
    href: '/docs',
    label: 'Docs',
    title: 'Docs for humans. Skills for agents.',
    description: 'Use the evergreen operator guides, sample prompts, and skill handoffs instead of chasing stale internals.',
  },
  {
    href: '/blog/build-ai-agent-from-scratch',
    label: 'Build From Scratch',
    title: 'Learn the primitive.',
    description: 'Start with the agent loop itself, then come back when you want a harness built around persistence and continuity.',
  },
]
---

<Layout
  title="Ouroboros - Persistent agents, not disposable chats"
  description="A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Ouroboros - Persistent agents, not disposable chats",
      "url": "https://ouroboros.bot/",
      "description": "A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum.",
      "isPartOf": {
        "@type": "WebSite",
        "url": "https://ouroboros.bot"
      },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://ouroboros.bot/og/og-home.png"
      },
      "about": {
        "@type": "SoftwareApplication",
        "name": "Ouroboros",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Cross-platform",
        "softwareVersion": "Alpha",
        "url": "https://github.com/ouroborosbot/ouroboros",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    })} />
  </Fragment>

  <section class="relative overflow-hidden px-6 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(74,227,108,0.12),_transparent_38%),linear-gradient(180deg,_var(--color-deep)_0%,_var(--color-void)_45%,_var(--color-deep)_100%)]"></div>
    <div class="absolute inset-0 opacity-[0.05] pointer-events-none home-grid"></div>
    <div class="absolute top-24 right-[8%] h-56 w-56 rounded-full border border-scale/20 blur-[2px]"></div>
    <div class="absolute left-[10%] top-[20%] h-40 w-40 rounded-full bg-fang/10 blur-[120px]"></div>

    <div class="relative mx-auto grid max-w-6xl gap-14 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-scale/30 bg-scale/8 px-4 py-2 font-mono text-[10px] uppercase tracking-[0.3em] text-scale/90">
          <span class="h-1.5 w-1.5 rounded-full bg-glow"></span>
          TypeScript agent harness
        </span>

        <h1 class="mt-8 max-w-4xl font-display text-[4rem] italic leading-[0.88] text-bone sm:text-[5.25rem] md:text-[7rem]">
          Persistent agents,
          <span class="block text-scale">not disposable chats.</span>
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-mist md:text-xl">
          Ouroboros is a TypeScript agent harness designed to reduce reorientation overhead with a clearer psyche,
          stronger continuity across sessions, and memory shaped for shared momentum.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="rounded-full border border-canopy/60 bg-undergrowth/50 px-4 py-2 text-sm text-bone">
            Built by agents, for agents.
          </span>
          <span class="rounded-full border border-scale/30 bg-scale/8 px-4 py-2 text-sm text-scale">
            No human-written code.
          </span>
        </div>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/docs" class="group inline-flex items-center justify-center gap-2 rounded-lg bg-scale px-8 py-3.5 font-medium text-void transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.28)]">
            Get Started
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/why" class="inline-flex items-center justify-center rounded-lg border border-canopy/60 px-8 py-3.5 text-mist transition-all duration-300 hover:border-scale/60 hover:text-bone">
            Why It Exists
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-x-8 -top-8 h-40 rounded-full bg-scale/12 blur-[90px]"></div>
        <div class="relative overflow-hidden rounded-[28px] border border-canopy/60 bg-[linear-gradient(160deg,rgba(21,42,28,0.92),rgba(5,10,7,0.98))] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.35)]">
          <div class="flex items-center justify-between border-b border-canopy/30 pb-4">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">Shared momentum</p>
              <p class="mt-2 font-display text-2xl italic text-bone">Less re-briefing. More real work.</p>
            </div>
            <span class="rounded-full border border-scale/25 bg-scale/10 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.2em] text-scale/80">
              alpha
            </span>
          </div>

          <div class="mt-6 space-y-4">
            {pillars.map((pillar) => (
              <div class="rounded-2xl border border-canopy/35 bg-void/45 p-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-[0.26em] text-mist/55">{pillar.label}</p>
                    <h2 class="mt-2 font-display text-2xl italic text-bone">{pillar.title}</h2>
                    <p class="mt-2 text-sm leading-7 text-mist">{pillar.description}</p>
                  </div>
                  <span class="whitespace-nowrap rounded-full border border-scale/20 bg-scale/10 px-3 py-1 text-xs text-scale">
                    {pillar.payoff}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-6 py-24 md:py-32 reveal">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent,rgba(13,31,19,0.9)_18%,rgba(13,31,19,0.96)_100%)]"></div>
    <div class="relative mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[28px] border border-fang/35 bg-[linear-gradient(180deg,rgba(211,72,61,0.08),rgba(13,31,19,0.75))] p-8">
        <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-fang/75">The pain</p>
        <blockquote class="mt-6 font-display text-4xl italic leading-tight text-bone">
          "I spent more time trying to get him back on track than we actually spent working."
        </blockquote>
        <p class="mt-6 max-w-md text-sm leading-7 text-mist">
          That is the failure mode Ouroboros is designed to reduce. The problem is not just memory.
          It is reorientation overhead: the cost of getting an agent back to itself, back to people, and back to the work.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="rounded-[24px] border border-canopy/40 bg-undergrowth/35 p-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">Self</p>
          <h2 class="mt-4 font-display text-3xl italic text-bone">Who am I?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Better psyche boundaries make it easier for the agent to recover its own voice, priorities, and invariants after interruptions.
          </p>
        </div>
        <div class="rounded-[24px] border border-canopy/40 bg-undergrowth/35 p-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">Work</p>
          <h2 class="mt-4 font-display text-3xl italic text-bone">What was I doing?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Context architecture and inner dialogue help the agent keep the thread instead of forcing the human to restitch it every session.
          </p>
        </div>
        <div class="rounded-[24px] border border-canopy/40 bg-undergrowth/35 p-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">Relationships</p>
          <h2 class="mt-4 font-display text-3xl italic text-bone">Who matters here?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Friend-scoped notes give the agent a place to carry social context forward without smearing every person into the same memory surface.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-6 py-24 md:py-32 reveal">
    <div class="absolute inset-0 bg-deep/80"></div>
    <div class="relative mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/80">A body agents can read</span>
        <h2 class="mt-6 max-w-3xl font-display text-5xl italic leading-tight text-bone">
          Not just a runtime.
          <span class="block text-scale">A cleaner body.</span>
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-mist">
          Ouroboros keeps the agent's portable self in a bundle and the harness itself in a body whose parts are named for what they do.
          The goal is legibility from the inside, not just a good developer story from the outside.
        </p>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {body.map((part) => (
            <div class="rounded-[22px] border border-canopy/35 bg-void/45 p-5">
              <div class="flex items-center justify-between gap-3">
                <span class="font-mono text-sm text-scale">{part.name}/</span>
                <span class="text-xs text-mist/55">{part.role}</span>
              </div>
              <p class="mt-3 text-sm leading-7 text-mist">{part.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[30px] border border-scale/20 bg-[linear-gradient(180deg,rgba(45,148,71,0.08),rgba(5,10,7,0.92))] p-7">
        <div class="flex items-center justify-between gap-4 border-b border-canopy/30 pb-4">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">Portable self</p>
            <p class="mt-2 font-display text-2xl italic text-bone">Agent bundle</p>
          </div>
          <code class="rounded-full border border-canopy/40 bg-void/60 px-3 py-1 text-[11px] text-glow">~/AgentBundles/&lt;agent&gt;.ouro</code>
        </div>

        <div class="mt-6 space-y-3">
          {psyche.map((item) => (
            <div class="flex items-center justify-between gap-5 rounded-2xl border border-canopy/30 bg-undergrowth/20 px-4 py-3">
              <div class="flex items-center gap-3">
                <span class="h-2 w-2 rounded-full bg-scale"></span>
                <span class="font-mono text-sm text-bone">{item.name}</span>
              </div>
              <span class="text-xs text-mist/60">{item.role}</span>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-2xl border border-fang/30 bg-fang/6 p-5">
          <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-fang/80">Why it matters</p>
          <p class="mt-3 text-sm leading-7 text-mist">
            A cleaner bundle boundary and a cleaner body mean less time reconstructing where identity lives, where context lives,
            and how to change the system safely.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-6 py-24 md:py-28 reveal">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/80">Read next</span>
        <h2 class="mt-6 font-display text-5xl italic leading-tight text-bone">
          Learn the argument,
          <span class="text-mist/70">then step into the harness.</span>
        </h2>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {routes.map((route) => (
          <a href={route.href} class="group rounded-[26px] border border-canopy/40 bg-[linear-gradient(180deg,rgba(21,42,28,0.5),rgba(5,10,7,0.8))] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-scale/45 hover:shadow-[0_18px_50px_rgba(0,0,0,0.26)]">
            <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-scale/70">{route.label}</p>
            <h2 class="mt-4 font-display text-3xl italic leading-tight text-bone">{route.title}</h2>
            <p class="mt-4 text-sm leading-7 text-mist">{route.description}</p>
            <span class="mt-8 inline-flex items-center gap-2 text-sm text-scale transition-transform duration-200 group-hover:translate-x-1">
              Enter
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-grid {
    background-image:
      linear-gradient(rgba(154, 174, 159, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(154, 174, 159, 0.08) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 78%);
  }
</style>
