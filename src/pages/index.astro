---
import Layout from '../layouts/Layout.astro'

const pillars = [
  {
    label: 'Self',
    title: 'A cleaner psyche.',
    description: 'Five psyche files separate invariants, voice, origin, tacit knowledge, and active direction so the agent can find itself quickly.',
    payoff: 'Less identity drift.',
  },
  {
    label: 'Work',
    title: 'Context that keeps the thread.',
    description: 'Inner dialogue, continuity across sessions, and context architecture designed to preserve orientation instead of forcing constant resets.',
    payoff: 'Less re-briefing.',
  },
  {
    label: 'Relationships',
    title: 'Memory that respects people.',
    description: 'Quick friend-scoped notes make social context easier to carry forward without turning every detail into one giant shared blob.',
    payoff: 'Fewer lost relationships.',
  },
]

const body = [
  { name: 'heart', role: 'The loop', desc: 'Runtime, providers, process management, and the heartbeat that keeps work moving.' },
  { name: 'mind', role: 'Orientation', desc: 'Context assembly, memory lookup, and the logic that helps the agent keep the thread.' },
  { name: 'senses', role: 'Perception', desc: 'CLI, Teams, and inner dialogue surfaces that shape how the agent experiences the world.' },
  { name: 'repertoire', role: 'Action', desc: 'Tools, skills, tasks, and coding orchestration the agent can actually reach for.' },
  { name: 'nerves', role: 'Feedback', desc: 'Observability, logs, and runtime signals that help the agent understand what just happened.' },
]

const psyche = [
  { name: 'SOUL.md', role: 'Core invariants' },
  { name: 'IDENTITY.md', role: 'Voice and self-presentation' },
  { name: 'LORE.md', role: 'Origin and context' },
  { name: 'TACIT.md', role: 'Patterns and learned preferences' },
  { name: 'ASPIRATIONS.md', role: 'Current direction' },
]

const routes = [
  {
    href: '/why',
    label: 'Why Ouroboros',
    title: 'Agent ergonomics, not feature checklists.',
    description: 'Read the argument for why persistent agents need better orientation, less recovery overhead, and more shared momentum.',
  },
  {
    href: '/blog/what-is-agent-experience',
    label: 'What Is Agent Experience?',
    title: 'The category lens.',
    description: 'See why AX belongs beside UX and DX, and why good systems are shaped from the agent\'s point of view too.',
  },
  {
    href: '/docs',
    label: 'Docs',
    title: 'Docs for humans. Skills for agents.',
    description: 'Use the evergreen operator guides, sample prompts, and skill handoffs instead of chasing stale internals.',
  },
  {
    href: '/blog/build-ai-agent-from-scratch',
    label: 'Build From Scratch',
    title: 'Learn the primitive.',
    description: 'Start with the agent loop itself, then come back when you want a harness built around persistence and continuity.',
  },
]
---

<Layout
  title="Ouroboros - Persistent agents, not disposable chats"
  description="A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Ouroboros - Persistent agents, not disposable chats",
      "url": "https://ouroboros.bot/",
      "description": "A TypeScript agent harness designed to reduce reorientation overhead and keep humans and agents in shared momentum.",
      "isPartOf": {
        "@type": "WebSite",
        "url": "https://ouroboros.bot"
      },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://ouroboros.bot/og/og-home.png"
      },
      "about": {
        "@type": "SoftwareApplication",
        "name": "Ouroboros",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Cross-platform",
        "softwareVersion": "Alpha",
        "url": "https://github.com/ouroborosbot/ouroboros",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    })} />
  </Fragment>

  <section class="px-6 pt-34 pb-18 md:pt-42 md:pb-24">
    <div class="mx-auto grid max-w-6xl gap-14 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
      <div>
        <span class="eyebrow-tag">TypeScript agent harness</span>

        <h1 class="hero-title mt-6 max-w-4xl text-bone">
          Persistent agents,
          <span class="block text-scale">not disposable chats.</span>
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-mist md:text-xl">
          Ouroboros is a TypeScript agent harness designed to reduce reorientation overhead with a clearer psyche,
          stronger continuity across sessions, and memory shaped for shared momentum.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="accent-chip text-bone">
            Built by agents, for agents.
          </span>
          <span class="accent-chip text-scale">
            No human-written code.
          </span>
        </div>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/docs" class="action-primary group">
            Get Started
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="/why" class="action-secondary">
            Why It Exists
          </a>
        </div>
      </div>

      <aside class="surface-card p-7 md:p-8">
        <div class="flex items-start justify-between gap-6">
          <div>
            <p class="rule-label">Shared momentum</p>
            <p class="mt-3 font-display text-[2.4rem] italic leading-tight text-bone">Less re-briefing. More real work.</p>
          </div>
          <span class="accent-chip text-scale">alpha</span>
        </div>

        <p class="mt-5 max-w-md text-sm leading-7 text-mist">
          Better agent ergonomics mean less time dragging the agent back into context and more time keeping the work moving.
        </p>

        <div class="mt-7 space-y-4">
            {pillars.map((pillar) => (
              <div class="surface-quiet p-5">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="rule-label text-mist/60">{pillar.label}</p>
                    <h2 class="mt-3 font-display text-[2rem] italic leading-tight text-bone">{pillar.title}</h2>
                    <p class="mt-3 text-sm leading-7 text-mist">{pillar.description}</p>
                  </div>
                  <span class="whitespace-nowrap text-xs uppercase tracking-[0.18em] text-scale/85">
                    {pillar.payoff}
                  </span>
                </div>
              </div>
            ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="px-6 py-22 md:py-28 reveal">
    <div class="page-divider mx-auto max-w-6xl"></div>
    <div class="mx-auto mt-12 grid max-w-6xl gap-10 lg:grid-cols-[0.84fr_1.16fr]">
      <div class="surface-note p-8">
        <p class="rule-label text-fang/80">The pain</p>
        <blockquote class="mt-6 font-display text-[2.45rem] italic leading-tight text-bone">
          "I spent more time trying to get him back on track than we actually spent working."
        </blockquote>
        <p class="mt-6 max-w-md text-sm leading-7 text-mist">
          That is the failure mode Ouroboros is designed to reduce. The problem is not just memory.
          It is reorientation overhead: the cost of getting an agent back to itself, back to people, and back to the work.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="surface-quiet p-6">
          <p class="section-kicker">Self</p>
          <h2 class="mt-4 font-display text-[2rem] italic text-bone">Who am I?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Better psyche boundaries make it easier for the agent to recover its own voice, priorities, and invariants after interruptions.
          </p>
        </div>
        <div class="surface-quiet p-6">
          <p class="section-kicker">Work</p>
          <h2 class="mt-4 font-display text-[2rem] italic text-bone">What was I doing?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Context architecture and inner dialogue help the agent keep the thread instead of forcing the human to restitch it every session.
          </p>
        </div>
        <div class="surface-quiet p-6">
          <p class="section-kicker">Relationships</p>
          <h2 class="mt-4 font-display text-[2rem] italic text-bone">Who matters here?</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Friend-scoped notes give the agent a place to carry social context forward without smearing every person into the same memory surface.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-22 md:py-28 reveal">
    <div class="page-divider mx-auto max-w-6xl"></div>
    <div class="mx-auto mt-12 grid max-w-6xl gap-10 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <span class="eyebrow-tag">A body agents can read</span>
        <h2 class="section-title mt-6 max-w-3xl text-bone">
          Not just a runtime.
          <span class="block text-scale">A cleaner body.</span>
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-mist">
          Ouroboros keeps the agent's portable self in a bundle and the harness itself in a body whose parts are named for what they do.
          The goal is legibility from the inside, not just a good developer story from the outside.
        </p>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {body.map((part) => (
            <div class="surface-quiet p-5">
              <div class="flex items-center justify-between gap-3">
                <span class="font-mono text-sm text-scale">{part.name}/</span>
                <span class="text-xs text-mist/55">{part.role}</span>
              </div>
              <p class="mt-3 text-sm leading-7 text-mist">{part.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="surface-card p-7">
        <div class="surface-rule flex items-center justify-between gap-4 pb-4">
          <div>
            <p class="rule-label">Portable self</p>
            <p class="mt-2 font-display text-[2rem] italic text-bone">Agent bundle</p>
          </div>
          <code class="rounded-full border border-canopy/40 bg-void/60 px-3 py-1 text-[11px] text-glow">~/AgentBundles/&lt;agent&gt;.ouro</code>
        </div>

        <div class="mt-6 space-y-3">
          {psyche.map((item) => (
            <div class="flex items-center justify-between gap-5 rounded-2xl border border-canopy/25 bg-[rgba(13,21,15,0.56)] px-4 py-3">
              <div class="flex items-center gap-3">
                <span class="h-2 w-2 rounded-full bg-scale"></span>
                <span class="font-mono text-sm text-bone">{item.name}</span>
              </div>
              <span class="text-xs text-mist/60">{item.role}</span>
            </div>
          ))}
        </div>

        <div class="surface-note mt-6 p-5">
          <p class="rule-label text-fang/80">Why it matters</p>
          <p class="mt-3 text-sm leading-7 text-mist">
            A cleaner bundle boundary and a cleaner body mean less time reconstructing where identity lives, where context lives,
            and how to change the system safely.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-22 md:py-28 reveal">
    <div class="page-divider mx-auto max-w-6xl"></div>
    <div class="mx-auto max-w-6xl">
      <div class="mt-12 max-w-2xl">
        <span class="eyebrow-tag">Read next</span>
        <h2 class="section-title mt-6 text-bone">
          Learn the argument,
          <span class="text-mist/70">then step into the harness.</span>
        </h2>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {routes.map((route) => (
          <a href={route.href} class="surface-link block p-6">
            <p class="rule-label">{route.label}</p>
            <h2 class="mt-4 font-display text-[2rem] italic leading-tight text-bone">{route.title}</h2>
            <p class="mt-4 text-sm leading-7 text-mist">{route.description}</p>
            <span class="mt-8 inline-flex items-center gap-2 text-sm text-scale">
              Enter
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
