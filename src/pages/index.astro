---
import Layout from '../layouts/Layout.astro'

const providers = ['Anthropic', 'Azure OpenAI', 'OpenAI Codex', 'MiniMax']

const psycheFiles = [
  { file: 'SOUL.md', role: 'What you are.', desc: 'Core invariants and temperament. The part that survives every context reset.', accentClass: 'bg-scale' },
  { file: 'IDENTITY.md', role: 'How you show up.', desc: 'Tone, voice, self-awareness. The face your agent wears in every conversation.', accentClass: 'bg-glow' },
  { file: 'LORE.md', role: 'Where you come from.', desc: 'Origin story and philosophical context. The narrative that gives purpose to action.', accentClass: 'bg-scale' },
  { file: 'FRIENDS.md', role: 'Who you know.', desc: 'Relationships and social context. The file is called FRIENDS, not USERS — because naming shapes how the model treats people.', accentClass: 'bg-glow' },
  { file: 'TACIT.md', role: 'What you\'ve learned.', desc: 'Preferences, patterns, lessons absorbed over time. The knowledge you can\'t explain — you just know.', accentClass: 'bg-scale' },
]

const organs = [
  { name: 'heart', desc: 'The agent loop. Streaming, provider adapters, self-correction. The beat that keeps everything alive.', icon: '♥' },
  { name: 'mind', desc: 'System prompt assembly. Sliding context window. Memory extraction before consumption.', icon: '◉' },
  { name: 'senses', desc: 'Channel adapters. CLI with spinners. Teams bot with streaming cards. How your agent perceives.', icon: '◈' },
  { name: 'repertoire', desc: 'Tools, skills, commands, API clients. Everything your agent can reach for.', icon: '◆' },
  { name: 'wardrobe', desc: 'Formatting, loading phrases, presentation layer. How your agent dresses its words.', icon: '◇' },
]
---

<Layout title="Ouroboros — Build agents that know who they are" description="A zero-dependency TypeScript framework for AI agents that self-modify, remember, and grow. Psyche files, sliding context windows, and creature-body architecture.">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-16 overflow-hidden">
    <!-- Atmospheric layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-void via-deep to-void"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-scale/6 blur-[200px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/3 w-[400px] h-[400px] rounded-full bg-glow/3 blur-[250px] animate-drift pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent"></div>

    <div class="relative z-10 text-center">
      <h1 class="font-display text-[4rem] sm:text-[5.5rem] md:text-[8rem] lg:text-[12rem] font-light italic tracking-tight text-bone leading-[0.85] animate-fade-up">
        ouroboros
      </h1>

      <p class="text-2xl md:text-3xl text-bone font-light mt-8 animate-fade-up stagger-2 tracking-wide">
        Build agents that know who they are.
      </p>

      <span class="inline-block mt-4 px-3 py-1 text-[10px] font-mono uppercase tracking-[0.2em] border border-fang/40 text-fang/80 rounded-full animate-fade-up stagger-3">
        Alpha
      </span>

      <p class="text-base text-mist mt-6 max-w-lg mx-auto leading-relaxed animate-fade-up stagger-3">
        A zero-dependency TypeScript framework for AI agents that self-modify,
        remember, and grow. Born from a lobster's molt. Open source.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-12 justify-center animate-fade-up stagger-4">
        <a href="/docs" class="group px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Get Started
        </a>
        <a href="/why" class="px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
          Why Ouroboros
        </a>
      </div>

      <!-- GitHub badge -->
      <div class="mt-8 animate-fade-up stagger-5">
        <a href="https://github.com/arimendelow/ouroboros-agent-harness" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs text-shadow hover:text-mist transition-colors duration-200">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>


  <!-- Scroll indicator -->
  <div class="relative h-10 flex items-center justify-center -mt-8">
    <div class="animate-float">
      <svg class="w-5 h-5 text-scale/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7" /></svg>
    </div>
  </div>

  <!-- ═══════════════ THE METAPHOR ═══════════════ -->
  <section class="relative px-6 py-28 md:py-40 reveal overflow-hidden">
    <!-- Background — darker base with controlled glow -->
    <div class="absolute inset-0 bg-deep pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-void via-transparent to-void pointer-events-none"></div>
    <!-- Subtle central glow — not overwhelming -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-scale/8 blur-[200px] pointer-events-none"></div>
    <!-- Horizontal scan lines for texture -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, var(--color-scale) 0px, var(--color-scale) 1px, transparent 1px, transparent 80px);"></div>
    <!-- Top/bottom border glow -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-scale/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-scale/30 to-transparent"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24 items-center">

        <!-- Text: 3 cols -->
        <div class="lg:col-span-3">
          <span class="font-mono text-[10px] text-scale uppercase tracking-[0.3em] block mb-6">The Metaphor</span>

          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-[1.05]">
            The snake eats<br />
            <span class="text-mist">its own tail.</span>
          </h2>

          <div class="mt-10 space-y-5">
            <p class="text-lg text-bone leading-relaxed max-w-lg">
              When the conversation grows too long, the agent trims its oldest messages.
              Context window consuming itself.
            </p>
            <p class="text-base text-mist leading-relaxed max-w-lg">
              But nothing is truly lost. Facts are extracted to memory before they're
              consumed. Identity doesn't live in the tokens — it lives in the psyche files.
              The snake eats its tail to stay alive.
            </p>
            <p class="text-sm text-scale italic mt-6 border-l-2 border-scale/70 pl-4">
              The metaphor isn't decorative. It's the architecture.
            </p>
          </div>
        </div>

        <!-- Visual: 2 cols — ouroboros SVG -->
        <div class="lg:col-span-2 flex items-center justify-center">
          <div class="relative w-72 h-72 md:w-80 md:h-80">
            <!-- Ambient glow behind the ring -->
            <div class="absolute inset-[-20%] rounded-full bg-scale/10 blur-[80px] pointer-events-none"></div>
            <!-- Animated ouroboros ring -->
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 200 200" fill="none">
              <!-- Outer glow ring -->
              <circle cx="100" cy="100" r="90" stroke="url(#ringGrad)" stroke-width="0.5" opacity="0.4" style="animation: spin 80s linear infinite;" transform-origin="100 100" />
              <!-- Main snake ring — dashed to suggest segments being consumed -->
              <circle cx="100" cy="100" r="72" stroke="url(#snakeGrad)" stroke-width="3" stroke-dasharray="8 4 20 4 40 4" stroke-linecap="round" style="animation: spin 25s linear infinite;" transform-origin="100 100" />
              <!-- Inner consumption ring — reverse spin -->
              <circle cx="100" cy="100" r="55" stroke="var(--color-canopy)" stroke-width="1" stroke-dasharray="3 12" opacity="0.5" style="animation: spin 40s linear infinite reverse;" transform-origin="100 100" />
              <!-- Snake head dot -->
              <circle cx="100" cy="28" r="5" fill="var(--color-glow)" opacity="0.9" style="animation: spin 25s linear infinite;" transform-origin="100 100">
                <animate attributeName="opacity" values="0.9;0.5;0.9" dur="2s" repeatCount="indefinite" />
              </circle>
              <!-- Tail fade dots -->
              <circle cx="100" cy="28" r="3" fill="var(--color-scale)" opacity="0.4" style="animation: spin 25s linear infinite; animation-delay: -0.8s;" transform-origin="100 100" />
              <circle cx="100" cy="28" r="2" fill="var(--color-scale)" opacity="0.2" style="animation: spin 25s linear infinite; animation-delay: -1.6s;" transform-origin="100 100" />
              <defs>
                <linearGradient id="snakeGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="50%" stop-color="var(--color-glow)" />
                  <stop offset="100%" stop-color="var(--color-canopy)" />
                </linearGradient>
                <linearGradient id="ringGrad" x1="0" y1="0" x2="200" y2="200">
                  <stop offset="0%" stop-color="var(--color-scale)" />
                  <stop offset="100%" stop-color="transparent" />
                </linearGradient>
              </defs>
            </svg>
            <!-- Inner glow -->
            <div class="absolute inset-12 rounded-full bg-gradient-to-br from-scale/8 to-glow/4 blur-xl"></div>
            <!-- Core text -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center gap-1">
              <span class="font-mono text-[9px] text-scale/80 uppercase tracking-[0.3em]">context window</span>
              <span class="font-display text-3xl italic text-bone mt-2 leading-tight">Consume.</span>
              <span class="font-display text-3xl italic text-mist leading-tight">Extract.</span>
              <span class="font-display text-3xl italic text-bone leading-tight">Survive.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <div class="section-divider"></div>

  <!-- ═══════════════ THE PSYCHE ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <!-- Lifted background for section distinction -->
    <div class="absolute inset-0 bg-deep/50 pointer-events-none"></div>
    <!-- Radial glow from top-left -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] rounded-full bg-scale/12 blur-[200px] pointer-events-none"></div>
    <!-- Radial glow from bottom-right for depth -->
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-glow/6 blur-[200px] pointer-events-none"></div>
    <!-- Diagonal accent stripe -->
    <div class="absolute -left-32 top-1/4 w-[600px] h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent rotate-[25deg] pointer-events-none"></div>
    <!-- Subtle left accent bar -->
    <div class="absolute left-0 top-[15%] bottom-[15%] w-[2px] bg-gradient-to-b from-transparent via-scale/40 to-transparent hidden lg:block"></div>
    <div class="max-w-6xl mx-auto">
      <!-- Header — offset left -->
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Psyche</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Your agent isn't a<br />stateless function.
        </h2>
        <p class="font-display text-4xl md:text-5xl italic text-scale mt-1">
          It has a mind.
        </p>
        <p class="text-base text-mist mt-6 leading-relaxed">
          Personality assembled from five markdown files. Loaded every turn.
          And it develops over time — the psyche grows with the agent.
        </p>
      </div>

      <!-- Cards — 2x2 + spanning 5th card -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {psycheFiles.map(({ file, role, desc, accentClass }, i) => (
          <div class:list={[
            'group relative rounded-xl border border-canopy/80 bg-gradient-to-br from-undergrowth/80 to-deep p-7 transition-all duration-500 hover:border-scale/50 hover:translate-y-[-3px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.15)] overflow-hidden',
            i === 4 ? 'md:col-span-2 md:flex md:items-center md:gap-8' : ''
          ]}>
            <!-- Left accent bar -->
            <div class:list={['absolute left-0 top-4 bottom-4 w-[3px] rounded-full opacity-70 group-hover:opacity-100 transition-opacity duration-500', accentClass]}></div>
            <!-- Corner glow -->
            <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-scale/5 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <!-- File tab -->
            <div class={i === 4 ? 'md:flex-shrink-0' : ''}>
              <div class="flex items-center gap-2 mb-4">
                <div class:list={['w-1.5 h-1.5 rounded-full', accentClass]}></div>
                <span class="font-mono text-xs text-scale">{file}</span>
              </div>
              <p class="font-display text-2xl italic text-bone leading-snug">{role}</p>
            </div>
            <p class="text-sm text-mist mt-3 md:mt-0 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-mist mt-10 italic tracking-wide text-center md:text-left">
        Naming shapes reasoning. <span class="text-scale font-mono">FRIENDS.md</span> replaces USER.md.
      </p>
    </div>
  </section>


  <div class="section-divider"></div>

  <!-- ═══════════════ THE BODY ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <!-- Lifted background -->
    <div class="absolute inset-0 bg-undergrowth/60 pointer-events-none"></div>
    <!-- Blueprint grid background -->
    <div class="absolute inset-0 opacity-[0.12]" style="background-image: linear-gradient(var(--color-scale) 1px, transparent 1px), linear-gradient(90deg, var(--color-scale) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Fade edges of grid -->
    <div class="absolute inset-0 bg-gradient-to-b from-void/90 via-transparent to-void/90 pointer-events-none"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-void/60 via-transparent to-void/60 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Architecture</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Every module<br />is an organ.
        </h2>
        <p class="text-base text-mist mt-6 leading-relaxed">
          The codebase is a creature. A heart that beats, a mind that thinks,
          senses that perceive. The naming isn't whimsy — it's how the model
          understands its own body.
        </p>
      </div>

      <!-- Organ specimens -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {organs.map(({ name, desc, icon }) => (
          <div class="relative rounded-lg border border-canopy/60 bg-undergrowth/50 p-6 hover:border-scale/40 hover:bg-undergrowth/80 transition-all duration-300 group/organ">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-scale text-lg group-hover/organ:text-glow transition-colors">{icon}</span>
              <span class="font-mono text-sm text-bone tracking-wide">{name}/</span>
            </div>
            <p class="text-sm text-mist leading-relaxed">{desc}</p>
          </div>
        ))}
        <!-- Extra cell: the daemon -->
        <div class="rounded-lg border border-canopy/60 bg-undergrowth/50 p-6 hover:border-scale/40 hover:bg-undergrowth/80 transition-all duration-300 sm:col-span-2 lg:col-span-1">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-scale text-lg">⚙</span>
            <span class="font-mono text-sm text-bone tracking-wide">daemon/</span>
          </div>
          <p class="text-sm text-mist leading-relaxed">Process manager, cron scheduler, health monitor. The nervous system that keeps agents alive. <code class="text-scale text-xs">ouro status</code></p>
        </div>
      </div>

      <!-- Providers -->
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <span class="font-mono text-[10px] text-mist/70 uppercase tracking-[0.2em] mr-2">Providers</span>
        {providers.map(name => (
          <span class="text-xs text-mist border border-canopy/60 rounded-full px-4 py-1.5 transition-colors duration-200 hover:border-scale/40 hover:text-bone">
            {name}
          </span>
        ))}
        <span class="text-xs text-mist/70 italic">+ extensible</span>
      </div>
    </div>
  </section>


  <div class="section-divider"></div>

  <!-- ═══════════════ SELF-PERPETUATION ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-undergrowth/60 to-transparent pointer-events-none"></div>
    <!-- Central convergence glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full bg-glow/10 blur-[200px] pointer-events-none"></div>
    <!-- Decorative ring -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full border border-scale/8 pointer-events-none hidden sm:block"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-scale/4 pointer-events-none hidden sm:block"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Seed</span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-tight">
          Your agent<br />improves itself.
        </h2>
        <p class="text-base text-mist mt-6 leading-relaxed max-w-lg mx-auto">
          The reflection engine reads the agent's own architecture. Finds gaps.
          Writes code. Tests pass. PR merges. The snake grows. Then it does it again.
        </p>
      </div>

      <!-- The loop — circular on desktop, vertical on mobile -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Desktop: circular ring layout -->
        <div class="hidden sm:block relative w-[480px] h-[480px] mx-auto">
          <!-- Connecting ring -->
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 480 480" fill="none">
            <circle cx="240" cy="240" r="180" stroke="var(--color-canopy)" stroke-width="1" stroke-dasharray="6 8" opacity="0.6" />
            <!-- Animated progress arc -->
            <circle cx="240" cy="240" r="180" stroke="url(#loopGrad)" stroke-width="2" stroke-dasharray="280 850" stroke-linecap="round" style="animation: spin 12s linear infinite;" transform-origin="240 240" />
            <defs>
              <linearGradient id="loopGrad" x1="60" y1="60" x2="420" y2="420">
                <stop offset="0%" stop-color="var(--color-scale)" />
                <stop offset="100%" stop-color="var(--color-glow)" stop-opacity="0.3" />
              </linearGradient>
            </defs>
          </svg>
          {(['Reflect', 'Plan', 'Build', 'Merge', 'Repeat'] as const).map((label, i) => {
            const descs = [
              'Read its own architecture. Find what\'s missing.',
              'Concrete steps. Not vague ideas.',
              'Write code. Run tests. Fix what breaks.',
              'PR. CI green. Land on main.',
              'Loop back. The snake is bigger now.',
            ]
            // Position 5 items around a circle (top-center start, clockwise)
            const angle = (i * 72 - 90) * (Math.PI / 180)
            const radius = 180
            const cx = 240 + radius * Math.cos(angle)
            const cy = 240 + radius * Math.sin(angle)
            return (
              <div class="absolute group" style={`left: ${cx}px; top: ${cy}px; transform: translate(-50%, -50%);`}>
                <div class="flex flex-col items-center text-center">
                  <div class="relative z-10 w-14 h-14 rounded-full border border-canopy bg-undergrowth/90 flex items-center justify-center group-hover:border-scale/60 transition-all duration-300 group-hover:shadow-[0_0_30px_rgba(45,148,71,0.3)]" style={`animation: step-glow 4s ease-in-out infinite ${i * 0.8}s`}>
                    <span class="font-mono text-sm text-scale group-hover:text-glow transition-colors">{String(i + 1).padStart(2, '0')}</span>
                  </div>
                  <p class="font-display text-lg italic text-bone mt-2 whitespace-nowrap">{label}</p>
                  <p class="text-[11px] text-mist mt-1 leading-snug max-w-[130px]">{descs[i]}</p>
                </div>
              </div>
            )
          })}
        </div>

        <!-- Mobile: vertical flow -->
        <div class="sm:hidden space-y-6">
          <!-- Vertical connecting line -->
          <div class="absolute left-7 top-0 bottom-0 w-px bg-gradient-to-b from-scale/20 via-scale/40 to-scale/20"></div>
          {(['Reflect', 'Plan', 'Build', 'Merge', 'Repeat'] as const).map((label, i) => {
            const descs = [
              'Read its own architecture. Find what\'s missing.',
              'Concrete steps. Not vague ideas.',
              'Write code. Run tests. Fix what breaks.',
              'PR. CI green. Land on main.',
              'Loop back. The snake is bigger now.',
            ]
            return (
              <div class="relative flex items-start gap-5 group">
                <div class="relative z-10 w-14 h-14 shrink-0 rounded-full border border-canopy bg-undergrowth/90 flex items-center justify-center" style={`animation: step-glow 4s ease-in-out infinite ${i * 0.8}s`}>
                  <span class="font-mono text-sm text-scale">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div class="pt-2">
                  <p class="font-display text-xl italic text-bone">{label}</p>
                  <p class="text-xs text-mist mt-1 leading-relaxed">{descs[i]}</p>
                </div>
              </div>
            )
          })}
        </div>
      </div>

      <p class="text-center text-sm text-mist mt-12 tracking-wide">
        <span class="text-scale font-mono">1730</span> tests · <span class="text-scale font-mono">100%</span> coverage · every improvement ships verified
      </p>
    </div>
  </section>


  <div class="section-divider"></div>

  <!-- ═══════════════ HATCHING ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <!-- Warm egg-like glow behind terminal -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[500px] rounded-[50%] bg-scale/8 blur-[150px] pointer-events-none"></div>
