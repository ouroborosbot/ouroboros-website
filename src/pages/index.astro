---
import Layout from '../layouts/Layout.astro'

const providers = ['Anthropic', 'Azure OpenAI', 'OpenAI Codex', 'MiniMax']

const psycheFiles = [
  { file: 'SOUL.md', role: 'What you are.', desc: 'Core invariants and temperament. The part that survives every context reset.', accent: 'scale' },
  { file: 'IDENTITY.md', role: 'How you show up.', desc: 'Tone, voice, self-awareness. The face your agent wears in every conversation.', accent: 'glow' },
  { file: 'LORE.md', role: 'Where you come from.', desc: 'Origin story and philosophical context. The narrative that gives purpose to action.', accent: 'scale' },
  { file: 'FRIENDS.md', role: 'Who you know.', desc: 'Relationships and social context. Not user IDs — friends. Partner, not user.', accent: 'glow' },
]

const organs = [
  { name: 'heart', desc: 'The agent loop. Streaming, provider adapters, self-correction. The beat that keeps everything alive.', icon: '♥' },
  { name: 'mind', desc: 'System prompt assembly. Sliding context window. Memory extraction before consumption.', icon: '◉' },
  { name: 'senses', desc: 'Channel adapters. CLI with spinners. Teams bot with streaming cards. How your agent perceives.', icon: '◈' },
  { name: 'repertoire', desc: 'Tools, skills, commands, API clients. Everything your agent can reach for.', icon: '◆' },
  { name: 'wardrobe', desc: 'Formatting, loading phrases, presentation layer. How your agent dresses its words.', icon: '◇' },
]
---

<Layout title="Ouroboros — Build agents that know who they are">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center px-6 overflow-hidden">
    <!-- Atmospheric layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-void via-deep to-void"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-scale/6 blur-[200px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent"></div>

    <div class="relative z-10 text-center">
      <h1 class="font-display text-[4rem] sm:text-[5.5rem] md:text-[8rem] lg:text-[12rem] font-light italic tracking-tight text-bone leading-[0.85] animate-fade-up">
        ouroboros
      </h1>

      <p class="text-xl md:text-2xl text-mist/80 font-light mt-8 animate-fade-up stagger-2 tracking-wide">
        Build agents that know who they are.
      </p>

      <p class="text-sm text-shadow mt-5 max-w-md mx-auto leading-relaxed animate-fade-up stagger-3">
        A zero-dependency TypeScript harness for AI agents that self-modify,
        remember, and grow. Born from a lobster's molt. Open source.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-12 justify-center animate-fade-up stagger-4">
        <a href="/docs" class="group px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Get Started
        </a>
        <a href="/blog/build-ai-agent-from-scratch" class="px-8 py-3.5 border border-canopy/60 text-mist rounded-lg hover:border-scale/60 hover:text-bone transition-all duration-300">
          How Agents Work
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════ THE METAPHOR ═══════════════ -->
  <section class="relative px-6 py-28 md:py-40 reveal overflow-hidden">
    <!-- Vertical accent -->
    <div class="absolute right-12 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-scale/20 to-transparent hidden lg:block"></div>

    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24 items-center">

        <!-- Text: 3 cols -->
        <div class="lg:col-span-3">
          <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Metaphor</span>

          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-[1.05]">
            The snake eats<br />
            <span class="text-mist/60">its own tail.</span>
          </h2>

          <div class="mt-10 space-y-5">
            <p class="text-lg text-mist leading-relaxed max-w-lg">
              When the conversation grows too long, the agent trims its oldest messages.
              Context window consuming itself.
            </p>
            <p class="text-base text-mist/70 leading-relaxed max-w-lg">
              But nothing is truly lost. Facts are extracted to memory before they're
              consumed. Identity doesn't live in the tokens — it lives in the psyche files.
              The snake eats its tail to stay alive.
            </p>
            <p class="text-sm text-shadow italic mt-6 border-l-2 border-scale/30 pl-4">
              The metaphor isn't decorative. It's the architecture.
            </p>
          </div>
        </div>

        <!-- Visual: 2 cols — concentric rings -->
        <div class="lg:col-span-2 flex items-center justify-center">
          <div class="relative w-72 h-72 md:w-80 md:h-80">
            <!-- Outermost ring: slow spin -->
            <div class="absolute inset-0 rounded-full border border-canopy/30" style="animation: spin 80s linear infinite;"></div>
            <!-- Second ring: reverse -->
            <div class="absolute inset-5 rounded-full border border-scale/15" style="animation: spin 55s linear infinite reverse;"></div>
            <!-- Third ring: tick marks suggest consumption -->
            <div class="absolute inset-10 rounded-full border border-dashed border-canopy/20" style="animation: spin 35s linear infinite;"></div>
            <!-- Inner glow -->
            <div class="absolute inset-16 rounded-full bg-gradient-to-br from-scale/8 to-transparent blur-md"></div>
            <!-- Core text -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center gap-1">
              <span class="font-mono text-[9px] text-scale/60 uppercase tracking-[0.3em]">context window</span>
              <span class="font-display text-3xl italic text-bone mt-2 leading-tight">Consume.</span>
              <span class="font-display text-3xl italic text-mist/50 leading-tight">Extract.</span>
              <span class="font-display text-3xl italic text-bone leading-tight">Survive.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════ THE PSYCHE ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <div class="max-w-6xl mx-auto">
      <!-- Header — offset left -->
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Psyche</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Your agent isn't a<br />stateless function.
        </h2>
        <p class="font-display text-4xl md:text-5xl italic text-mist/40 mt-1">
          It has a mind.
        </p>
        <p class="text-base text-mist/70 mt-6 leading-relaxed">
          Personality assembled from four markdown files. Loaded every turn.
          And it develops over time — the psyche grows with the agent.
        </p>
      </div>

      <!-- Cards — 2x2 grid, feel like journal pages -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {psycheFiles.map(({ file, role, desc, accent }) => (
          <div class="group relative rounded-xl border border-canopy/40 bg-gradient-to-br from-deep/90 to-undergrowth/30 p-7 transition-all duration-500 hover:border-scale/30 hover:translate-y-[-3px] hover:shadow-[0_8px_40px_rgba(45,148,71,0.08)]">
            <!-- File tab -->
            <div class="flex items-center gap-2 mb-4">
              <div class={`w-1.5 h-1.5 rounded-full bg-${accent}`}></div>
              <span class="font-mono text-xs text-scale/70">{file}</span>
            </div>
            <p class="font-display text-2xl italic text-bone leading-snug">{role}</p>
            <p class="text-sm text-mist/60 mt-3 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-shadow/60 mt-8 italic tracking-wide">
        "Partner, not user." — FRIENDS.md replaces USER.md.
      </p>
    </div>
  </section>


  <!-- ═══════════════ THE BODY ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <!-- Blueprint grid background hint -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(var(--color-scale) 1px, transparent 1px), linear-gradient(90deg, var(--color-scale) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="max-w-xl mb-14">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Architecture</span>
        <h2 class="font-display text-5xl md:text-6xl italic text-bone leading-tight">
          Every module<br />is an organ.
        </h2>
        <p class="text-base text-mist/70 mt-6 leading-relaxed">
          The codebase is a creature. A heart that beats, a mind that thinks,
          senses that perceive. The naming isn't whimsy — it's how the model
          understands its own body.
        </p>
      </div>

      <!-- Organ specimens -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-canopy/20 rounded-xl overflow-hidden">
        {organs.map(({ name, desc, icon }) => (
          <div class="bg-deep/95 p-6 hover:bg-undergrowth/40 transition-colors duration-300">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-scale/60 text-base">{icon}</span>
              <span class="font-mono text-sm text-bone tracking-wide">{name}/</span>
            </div>
            <p class="text-sm text-mist/60 leading-relaxed">{desc}</p>
          </div>
        ))}
        <!-- Extra cell: the daemon -->
        <div class="bg-deep/95 p-6 hover:bg-undergrowth/40 transition-colors duration-300 sm:col-span-2 lg:col-span-1">
          <div class="flex items-baseline gap-3 mb-3">
            <span class="text-scale/60 text-base">⚙</span>
            <span class="font-mono text-sm text-bone tracking-wide">daemon/</span>
          </div>
          <p class="text-sm text-mist/60 leading-relaxed">Process manager, cron scheduler, health monitor. The nervous system that keeps agents alive. <code class="text-scale/70 text-xs">ouro status</code></p>
        </div>
      </div>

      <!-- Providers -->
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <span class="font-mono text-[10px] text-shadow/50 uppercase tracking-[0.2em] mr-2">Providers</span>
        {providers.map(name => (
          <span class="text-xs text-mist/50 border border-canopy/30 rounded-full px-4 py-1.5 transition-colors duration-200 hover:border-scale/30 hover:text-mist/80">
            {name}
          </span>
        ))}
        <span class="text-xs text-shadow/40 italic">+ extensible</span>
      </div>
    </div>
  </section>


  <!-- ═══════════════ SELF-PERPETUATION ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-undergrowth/15 to-transparent pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">The Seed</span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl italic text-bone leading-tight">
          Your agent<br />improves itself.
        </h2>
        <p class="text-base text-mist/70 mt-6 leading-relaxed max-w-lg mx-auto">
          The reflection engine reads the agent's own architecture. Finds gaps.
          Writes code. Tests pass. PR merges. The snake grows. Then it does it again.
        </p>
      </div>

      <!-- The loop — continuous flow -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Connecting line -->
        <div class="absolute top-1/2 left-0 right-0 h-px bg-gradient-to-r from-transparent via-canopy/40 to-transparent -translate-y-1/2 hidden sm:block"></div>

        <div class="grid grid-cols-1 sm:grid-cols-5 gap-6 sm:gap-2">
          {(['Reflect', 'Plan', 'Build', 'Merge', 'Repeat'] as const).map((label, i) => {
            const descs = [
              'Read its own architecture. Find what\'s missing.',
              'Concrete steps. Not vague ideas.',
              'Write code. Run tests. Fix what breaks.',
              'PR. CI green. Land on main.',
              'Loop back. The snake is bigger now.',
            ]
            return (
              <div class="relative group flex sm:flex-col items-center sm:items-center gap-4 sm:gap-0 sm:text-center">
                <!-- Step circle -->
                <div class="relative z-10 w-10 h-10 sm:w-12 sm:h-12 shrink-0 rounded-full border border-canopy/50 bg-deep flex items-center justify-center group-hover:border-scale/50 transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(45,148,71,0.15)]">
                  <span class="font-mono text-[10px] text-scale/60">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div class="sm:mt-4">
                  <p class="font-display text-lg italic text-bone">{label}</p>
                  <p class="text-[11px] text-mist/50 mt-1 sm:mt-2 leading-relaxed">{descs[i]}</p>
                </div>
              </div>
            )
          })}
        </div>
      </div>

      <p class="text-center text-xs text-shadow/50 mt-12 tracking-wide">
        1730 tests · 100% coverage · every improvement ships verified
      </p>
    </div>
  </section>


  <!-- ═══════════════ HATCHING ═══════════════ -->
  <section class="relative px-6 py-28 md:py-36 reveal">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <span class="font-mono text-[10px] text-scale/80 uppercase tracking-[0.3em] block mb-6">Begin</span>
        <h2 class="font-display text-4xl md:text-6xl italic text-bone leading-tight">
          Hatch your first agent.
        </h2>
        <p class="text-sm text-mist/60 mt-4">
          Every agent starts as an egg. A directory with a psyche and a purpose.
        </p>
      </div>

      <!-- Terminal -->
      <div class="max-w-2xl mx-auto rounded-xl border border-canopy/40 bg-deep/90 overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.3)]">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-canopy/30 bg-undergrowth/30">
          <span class="w-2.5 h-2.5 rounded-full bg-fang/50"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-scale/30"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-canopy/40"></span>
          <span class="font-mono text-[10px] text-shadow/40 ml-3">~/agents</span>
        </div>
        <pre class="p-6 text-sm font-mono leading-loose overflow-x-auto"><code><span class="text-shadow/50"># hatch your agent</span>
<span class="text-mist">$</span> <span class="text-bone">ouro hatch my-agent</span>
<span class="inline-block px-2 py-0.5 text-[9px] uppercase tracking-wider border border-scale/25 rounded text-scale/50">coming soon</span>

<span class="text-shadow/50"># or create by hand</span>
<span class="text-mist">$</span> <span class="text-bone">mkdir -p my-agent/psyche</span>

<span class="text-bone">my-agent/</span>
  <span class="text-mist">agent.json</span>         <span class="text-shadow/40"># name, provider, config</span>
  <span class="text-mist">psyche/</span>
    <span class="text-glow/70">SOUL.md</span>          <span class="text-shadow/40"># what you are</span>
    <span class="text-glow/70">IDENTITY.md</span>      <span class="text-shadow/40"># how you show up</span>
    <span class="text-glow/70">LORE.md</span>          <span class="text-shadow/40"># where you come from</span>
    <span class="text-glow/70">FRIENDS.md</span>       <span class="text-shadow/40"># who you know</span>

<span class="text-mist">$</span> <span class="text-bone">npm run dev -- --agent my-agent</span></code></pre>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-12">
        <a href="/docs" class="group inline-flex items-center justify-center gap-2.5 px-8 py-3.5 bg-scale text-void font-medium rounded-lg transition-all duration-300 hover:bg-glow hover:shadow-[0_0_40px_rgba(45,148,71,0.3)]">
          Read the Docs
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="/story" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border border-canopy/50 text-mist rounded-lg hover:border-scale/40 hover:text-bone transition-all duration-300">
          How We Got Here
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
