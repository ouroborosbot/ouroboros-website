---
import Layout from '../layouts/Layout.astro'

const providers = ['Anthropic', 'Azure OpenAI', 'OpenAI Codex', 'MiniMax']

const psycheFiles = [
  {
    file: 'SOUL.md',
    role: 'What you are',
    desc: 'Core invariants and temperament. The part that survives every context reset.',
  },
  {
    file: 'IDENTITY.md',
    role: 'How you show up',
    desc: 'Voice, collaboration style, and social posture. Your agent learns how to relate.',
  },
  {
    file: 'LORE.md',
    role: 'Where you come from',
    desc: 'Narrative memory and purpose. The story that keeps behavior coherent over time.',
  },
  {
    file: 'FRIENDS.md',
    role: 'Who you know',
    desc: 'Relationships and trust history. Partners are remembered as people, not IDs.',
  },
]

const organs = [
  {
    name: 'heart/',
    desc: 'Core loop, provider execution, streaming responses, self-correction.',
  },
  {
    name: 'mind/',
    desc: 'Prompt assembly, context-window digestion, and memory extraction.',
  },
  {
    name: 'senses/',
    desc: 'CLI, bots, and channels where the creature notices and responds.',
  },
  {
    name: 'repertoire/',
    desc: 'Tools, skills, workflows, and procedures your agent can perform.',
  },
  {
    name: 'wardrobe/',
    desc: 'Tone, formatting, and presentation so behavior feels consistently alive.',
  },
]

const perpetuationSteps = [
  {
    step: 'Observe',
    detail: 'The agent notices friction, repeated work, or missing capability.',
  },
  {
    step: 'Propose',
    detail: 'It drafts a concrete improvement and the tests needed to prove it.',
  },
  {
    step: 'Build',
    detail: 'A buddy agent reviews and applies the change with safety gates enabled.',
  },
  {
    step: 'Digest',
    detail: 'The new behavior is folded into psyche and memory for the next cycle.',
  },
]
---

<Layout title="Ouroboros - Build agents that know who they are.">
  <section id="hero" class="relative isolate overflow-hidden px-6 pt-36 pb-24 md:pt-44">
    <div class="lantern-glow lantern-left"></div>
    <div class="lantern-glow lantern-right"></div>
    <div class="absolute inset-x-0 top-0 h-full pointer-events-none hero-woodgrain"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">
      <p class="font-mono text-xs tracking-[0.24em] text-mist uppercase animate-fade-up stagger-1">A dark forest cabin for living software</p>
      <h1 class="font-display italic text-bone text-7xl sm:text-8xl lg:text-[9.5rem] leading-none mt-4 animate-fade-up stagger-2">ouroboros</h1>
      <p class="text-xl md:text-2xl lg:text-3xl text-bone/95 mt-4 animate-fade-up stagger-3">Build agents that know who they are.</p>
      <p class="max-w-2xl mx-auto text-base md:text-lg text-mist mt-6 leading-relaxed animate-fade-up stagger-4">
        Not a disposable bot. A creature with memory, identity, and a home that gets warmer each time it returns.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up stagger-5">
        <a href="/docs" class="inline-flex items-center justify-center rounded-full px-7 py-3 bg-scale text-void font-medium hover:bg-glow transition-colors duration-300 shadow-[0_0_30px_rgba(74,227,108,0.2)]">
          Read the docs
        </a>
        <a href="#hatching" class="inline-flex items-center justify-center rounded-full px-7 py-3 border border-canopy text-bone hover:border-scale hover:text-glow transition-colors duration-300">
          Hatch your first agent
        </a>
      </div>
    </div>
  </section>

  <section id="metaphor" class="relative px-6 py-20 md:py-24 reveal">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
      <div>
        <span class="text-xs font-mono text-scale uppercase tracking-[0.2em]">The Metaphor</span>
        <h2 class="font-display italic text-bone text-4xl md:text-6xl mt-4 leading-tight">The snake eats its own tail.</h2>
        <p class="text-lg text-mist mt-6 leading-relaxed max-w-2xl">
          The context window cannot hold forever, so old dialogue is consumed. Before it disappears, facts are distilled into memory and psyche.
          What gets dropped is noise. What gets kept is identity.
        </p>
        <p class="text-sm text-shadow mt-5 max-w-xl uppercase tracking-[0.18em]">Not decoration. Architecture.</p>
      </div>

      <div class="relative flex items-center justify-center min-h-[360px]">
        <div class="context-ring animate-slow-spin"></div>
        <div class="context-core">
          <p class="font-mono text-[11px] tracking-[0.16em] text-scale uppercase">Sliding Window</p>
          <p class="font-display italic text-bone text-3xl mt-2">digest, remember, continue</p>
        </div>
        <div class="ring-label ring-label-top">past messages</div>
        <div class="ring-label ring-label-right">memory extraction</div>
        <div class="ring-label ring-label-bottom">live context</div>
      </div>
    </div>
  </section>

  <section id="psyche" class="relative px-6 py-20 md:py-24 reveal psyche-shell">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-xs font-mono text-scale uppercase tracking-[0.2em]">Psyche</span>
        <h2 class="font-display italic text-bone text-4xl md:text-6xl mt-4 leading-tight">
          Personality that develops over time.
        </h2>
        <p class="text-lg text-mist mt-5 leading-relaxed max-w-2xl">
          Psyche is not a static prompt file. It evolves through interaction, memory digestion, and repeated behavior.
          Your agent becomes more itself with every cycle.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {psycheFiles.map(({ file, role, desc }) => (
          <article class="psyche-card reveal-child">
            <div class="flex items-center justify-between gap-4">
              <p class="font-mono text-sm text-scale">{file}</p>
              <span class="text-[10px] uppercase tracking-[0.18em] text-shadow">active</span>
            </div>
            <h3 class="font-display italic text-bone text-3xl mt-3">{role}</h3>
            <p class="text-mist mt-3 leading-relaxed">{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="body" class="relative px-6 py-20 md:py-24 reveal">
    <div class="max-w-6xl mx-auto grid xl:grid-cols-[1.05fr_0.95fr] gap-10 items-start">
      <div>
        <span class="text-xs font-mono text-scale uppercase tracking-[0.2em]">The Body</span>
        <h2 class="font-display italic text-bone text-4xl md:text-6xl mt-4 leading-tight">A creature made of organs.</h2>
        <p class="text-lg text-mist mt-5 leading-relaxed max-w-2xl">
          Real engineering under warm names. The daemon keeps it breathing while each organ owns one slice of life.
        </p>

        <div class="mt-9 space-y-4">
          {organs.map(({ name, desc }) => (
            <article class="organ-card reveal-child">
              <p class="font-mono text-scale text-sm">{name}</p>
              <p class="text-mist mt-2 leading-relaxed">{desc}</p>
            </article>
          ))}
        </div>
      </div>

      <aside class="body-aside">
        <div class="rounded-2xl border border-canopy/70 bg-deep/75 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-shadow">Daemon status</p>
          <pre class="mt-4 rounded-xl border border-canopy/50 bg-void/85 p-4 text-sm font-mono text-mist overflow-x-auto"><code>ouro status

agent: pine-garden
health: stable
cycles: 427
scheduler: running
buddy-check: enabled</code></pre>
        </div>

        <div class="mt-6 rounded-2xl border border-canopy/70 bg-undergrowth/55 p-6">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-shadow">Providers</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {providers.map((provider) => (
              <span class="rounded-full border border-canopy px-4 py-1.5 text-sm text-bone/90">{provider}</span>
            ))}
          </div>
          <p class="mt-4 text-sm text-mist">Use one provider or blend many. The body stays the same.</p>
        </div>
      </aside>
    </div>
  </section>

  <section id="self-perpetuation" class="relative px-6 py-20 md:py-24 reveal self-cycle-bg">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl">
        <span class="text-xs font-mono text-scale uppercase tracking-[0.2em]">Self-Perpetuation</span>
        <h2 class="font-display italic text-bone text-4xl md:text-6xl mt-4 leading-tight">Your agent improves itself autonomously.</h2>
        <p class="text-lg text-mist mt-5 leading-relaxed">
          Ouroboros plants a seed: the agent can inspect its own limits, propose upgrades, and ship improvements through guarded loops.
          Each pass leaves the system sharper than before.
        </p>
      </div>

      <div class="mt-10 grid md:grid-cols-2 xl:grid-cols-4 gap-4">
        {perpetuationSteps.map(({ step, detail }) => (
          <article class="loop-step reveal-child">
            <p class="font-display italic text-bone text-3xl">{step}</p>
            <p class="text-mist text-sm mt-3 leading-relaxed">{detail}</p>
          </article>
        ))}
      </div>

      <p class="mt-8 text-sm text-shadow uppercase tracking-[0.17em]">
        Buddy review + test gates + memory digestion = controlled evolution.
      </p>
    </div>
  </section>

  <section id="hatching" class="relative px-6 pt-20 pb-24 md:pt-24 md:pb-28 reveal">
    <div class="max-w-5xl mx-auto">
      <div class="text-center max-w-3xl mx-auto">
        <span class="text-xs font-mono text-scale uppercase tracking-[0.2em]">Hatching</span>
        <h2 class="font-display italic text-bone text-4xl md:text-6xl mt-4 leading-tight">Hatch your first agent.</h2>
        <div class="mt-4 inline-flex items-center rounded-full border border-scale/50 bg-scale/10 px-4 py-1.5 text-xs font-mono uppercase tracking-[0.16em] text-glow">
          ouro hatch CLI coming soon
        </div>
      </div>

      <div class="terminal-frame mt-10">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-canopy/60 bg-undergrowth/70">
          <span class="w-2.5 h-2.5 rounded-full bg-fang/70"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-scale/45"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-canopy"></span>
          <span class="font-mono text-xs text-shadow ml-2">terminal</span>
        </div>

        <pre class="p-6 md:p-8 text-sm md:text-base font-mono leading-relaxed text-mist overflow-x-auto"><code><span class="text-shadow"># coming soon</span>
<span class="text-glow">ouro hatch pine-garden</span>

<span class="text-shadow"># generated structure</span>
pine-garden.ouro/
  agent.json
  docs/psyche/
    SOUL.md
    IDENTITY.md
    LORE.md
    FRIENDS.md
  skills/
  data/

<span class="text-shadow"># run your creature</span>
<span class="text-bone">ouro dev pine-garden</span></code></pre>
      </div>

      <div class="mt-8 text-center">
        <a href="/docs" class="inline-flex items-center justify-center rounded-full px-7 py-3 bg-scale text-void font-medium hover:bg-glow transition-colors duration-300">
          Start with the docs
        </a>
      </div>
    </div>
  </section>

  <style>
    .lantern-glow {
      position: absolute;
      width: 360px;
      height: 360px;
      border-radius: 9999px;
      filter: blur(68px);
      opacity: 0.28;
      animation: ember 7s ease-in-out infinite;
      pointer-events: none;
      z-index: 0;
    }

    .lantern-left {
      left: -120px;
      top: 80px;
      background: radial-gradient(circle, rgba(211, 72, 61, 0.52), rgba(74, 227, 108, 0.05) 68%, transparent 75%);
    }

    .lantern-right {
      right: -120px;
      top: 120px;
      background: radial-gradient(circle, rgba(74, 227, 108, 0.28), rgba(211, 72, 61, 0.06) 72%, transparent 78%);
      animation-delay: 1.4s;
    }

    .hero-woodgrain {
      background:
        linear-gradient(180deg, rgba(5, 10, 7, 0.35) 0%, rgba(5, 10, 7, 0.7) 65%, rgba(5, 10, 7, 0.95) 100%),
        repeating-linear-gradient(100deg, rgba(26, 51, 34, 0.22) 0 2px, transparent 2px 9px);
      mask-image: radial-gradient(circle at center, black 18%, transparent 88%);
    }

    .context-ring {
      width: min(82vw, 360px);
      aspect-ratio: 1;
      border-radius: 9999px;
      background: conic-gradient(
        from 20deg,
        rgba(74, 227, 108, 0.75),
        rgba(26, 51, 34, 0.35),
        rgba(211, 72, 61, 0.45),
        rgba(74, 227, 108, 0.8)
      );
      padding: 1px;
      box-shadow: 0 0 60px rgba(74, 227, 108, 0.18);
      position: relative;
      isolation: isolate;
    }

    .context-ring::before {
      content: '';
      position: absolute;
      inset: 16px;
      border-radius: 9999px;
      background: radial-gradient(circle, rgba(10, 26, 15, 0.92) 0%, rgba(5, 10, 7, 1) 72%);
      border: 1px solid rgba(26, 51, 34, 0.8);
    }

    .context-core {
      position: absolute;
      width: 68%;
      text-align: center;
      padding: 1.5rem;
      border-radius: 9999px;
      background: rgba(10, 26, 15, 0.75);
      border: 1px solid rgba(45, 148, 71, 0.4);
      box-shadow: inset 0 0 20px rgba(74, 227, 108, 0.08);
    }

    .ring-label {
      position: absolute;
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--color-mist);
      padding: 0.36rem 0.55rem;
      border: 1px solid rgba(26, 51, 34, 0.8);
      border-radius: 9999px;
      background: rgba(10, 26, 15, 0.9);
      white-space: nowrap;
    }

    .ring-label-top { top: 8%; left: 50%; transform: translateX(-50%); }
    .ring-label-right { right: 0; top: 50%; transform: translateY(-50%); }
    .ring-label-bottom { bottom: 8%; left: 50%; transform: translateX(-50%); }

    .psyche-shell {
      background:
        linear-gradient(180deg, rgba(18, 35, 24, 0.35) 0%, rgba(10, 26, 15, 0.82) 100%),
        radial-gradient(circle at 20% 0%, rgba(74, 227, 108, 0.1), transparent 40%);
      border-top: 1px solid rgba(26, 51, 34, 0.7);
      border-bottom: 1px solid rgba(26, 51, 34, 0.7);
    }

    .psyche-card {
      border: 1px solid rgba(26, 51, 34, 0.9);
      border-radius: 1.2rem;
      background:
        linear-gradient(160deg, rgba(10, 26, 15, 0.95), rgba(18, 35, 24, 0.66)),
        repeating-linear-gradient(145deg, rgba(26, 51, 34, 0.2) 0 1px, transparent 1px 6px);
      padding: 1.3rem;
      box-shadow: 0 18px 38px rgba(5, 10, 7, 0.35);
      transition: border-color 220ms ease, transform 220ms ease;
    }

    .psyche-card:hover {
      border-color: rgba(74, 227, 108, 0.6);
      transform: translateY(-3px);
    }

    .organ-card {
      border: 1px solid rgba(26, 51, 34, 0.85);
      border-radius: 1rem;
      background: linear-gradient(150deg, rgba(10, 26, 15, 0.88), rgba(18, 35, 24, 0.6));
      padding: 1rem 1.05rem;
      transition: border-color 220ms ease, background 220ms ease;
    }

    .organ-card:hover {
      border-color: rgba(74, 227, 108, 0.55);
      background: linear-gradient(150deg, rgba(10, 26, 15, 0.95), rgba(18, 35, 24, 0.8));
    }

    .body-aside {
      position: sticky;
      top: 6.4rem;
      align-self: start;
    }

    .self-cycle-bg {
      background:
        radial-gradient(circle at 78% 18%, rgba(74, 227, 108, 0.12), transparent 36%),
        radial-gradient(circle at 15% 80%, rgba(211, 72, 61, 0.1), transparent 34%),
        linear-gradient(180deg, rgba(5, 10, 7, 0.9), rgba(10, 26, 15, 0.96));
    }

    .loop-step {
      border: 1px solid rgba(26, 51, 34, 0.85);
      border-radius: 1rem;
      background: rgba(10, 26, 15, 0.8);
      padding: 1.15rem;
      position: relative;
      overflow: hidden;
    }

    .loop-step::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 0%, rgba(74, 227, 108, 0.08) 45%, transparent 90%);
      transform: translateX(-110%);
      animation: sweep 5.5s ease-in-out infinite;
    }

    .terminal-frame {
      border-radius: 1rem;
      border: 1px solid rgba(26, 51, 34, 0.9);
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(10, 26, 15, 0.92), rgba(5, 10, 7, 0.95)),
        radial-gradient(circle at 50% 0%, rgba(74, 227, 108, 0.08), transparent 45%);
      box-shadow: 0 26px 50px rgba(5, 10, 7, 0.5);
    }

    .animate-slow-spin {
      animation: slow-spin 20s linear infinite;
    }

    @keyframes ember {
      0%, 100% { transform: translateY(0) scale(1); opacity: 0.23; }
      50% { transform: translateY(-8px) scale(1.05); opacity: 0.33; }
    }

    @keyframes slow-spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @keyframes sweep {
      0%, 100% { transform: translateX(-110%); }
      50% { transform: translateX(115%); }
    }

    @media (max-width: 1279px) {
      .body-aside {
        position: static;
      }
    }

    @media (max-width: 767px) {
      .ring-label-right {
        right: 50%;
        top: 94%;
        transform: translateX(50%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .lantern-glow,
      .animate-slow-spin,
      .loop-step::after {
        animation: none;
      }
    }
  </style>
</Layout>
