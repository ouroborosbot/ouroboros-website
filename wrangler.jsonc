{
	"name": "ouroboros-website",
  "compatibility_date": "2026-03-06",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "ouroboros.bot/*", "zone_name": "ouroboros.bot" }
  ]
}